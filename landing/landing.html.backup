<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Xela Themes - Professional VS Code theme collection">
    <title>Xela Themes</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-primary: #0a0a0a;
            --bg-secondary: #1a1a1a;
            --text-primary: #ffffff;
            --text-secondary: #a0a0a0;
            --accent: #00ff88;
            --transition-speed: 0.3s;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* WebGL Canvas Background */
        #webgl-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            opacity: 0.4;
        }

        /* Layout */
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        /* Header */
        header {
            padding: 2rem 0;
            backdrop-filter: blur(10px);
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(10, 10, 10, 0.8);
        }

        header .container {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: -0.02em;
        }

        nav ul {
            display: flex;
            gap: 2rem;
            list-style: none;
        }

        nav a {
            color: var(--text-secondary);
            text-decoration: none;
            transition: color var(--transition-speed);
        }

        nav a:hover {
            color: var(--text-primary);
        }

        /* Hero Section */
        .hero {
            min-height: 90vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 4rem 0;
        }

        .hero h1 {
            font-size: clamp(2.5rem, 8vw, 6rem);
            font-weight: 800;
            margin-bottom: 1.5rem;
            letter-spacing: -0.03em;
            line-height: 1.1;
        }

        .hero p {
            font-size: clamp(1rem, 2vw, 1.5rem);
            color: var(--text-secondary);
            max-width: 600px;
            margin: 0 auto 2rem;
        }

        .cta-button {
            display: inline-block;
            padding: 1rem 2.5rem;
            background: var(--accent);
            color: var(--bg-primary);
            text-decoration: none;
            font-weight: 600;
            border-radius: 0.5rem;
            transition: transform var(--transition-speed), box-shadow var(--transition-speed);
        }

        .cta-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(0, 255, 136, 0.3);
        }

        /* Screenshot Gallery - Isometric Card Deck */
        .gallery {
            padding: 6rem 0;
            min-height: 100vh;
            perspective: 2000px;
            position: relative;
        }

        .gallery h2 {
            font-size: clamp(2rem, 5vw, 3.5rem);
            font-weight: 700;
            margin-bottom: 6rem;
            text-align: center;
        }

        /* SVG Filters for Displacement */
        .svg-filters {
            position: absolute;
            width: 0;
            height: 0;
            pointer-events: none;
        }

        /* Card Deck Container */
        .gallery-grid {
            position: relative;
            height: 800px;
            margin: 0 auto;
            max-width: 1600px;
            transform-style: preserve-3d;
        }

        /* Individual Theme Card in Deck */
        .theme-card {
            position: absolute;
            width: 520px;
            height: 340px;
            background: linear-gradient(135deg, #1a1a1a 0%, #0f0f0f 100%);
            border-radius: 24px;
            cursor: pointer;
            transform-style: preserve-3d;
            transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
            box-shadow:
                0 30px 60px rgba(0, 0, 0, 0.6),
                inset 0 1px 0 rgba(255, 255, 255, 0.1),
                0 0 0 1px rgba(255, 255, 255, 0.05);
            filter: url(#displacement-wave);
            overflow: hidden;
            backface-visibility: hidden;
            will-change: transform, filter;
        }

        .theme-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(
                135deg,
                rgba(0, 255, 136, 0.1) 0%,
                transparent 50%,
                rgba(0, 200, 255, 0.1) 100%
            );
            opacity: 0;
            transition: opacity 0.6s ease;
            border-radius: 24px;
        }

        .theme-card:hover::before {
            opacity: 1;
        }

        .theme-card:hover {
            filter: url(#displacement-wave-intense) brightness(1.1);
            box-shadow:
                0 50px 100px rgba(0, 255, 136, 0.3),
                inset 0 1px 0 rgba(255, 255, 255, 0.2),
                0 0 0 2px rgba(0, 255, 136, 0.3);
            z-index: 100 !important;
        }

        .theme-card-image {
            width: 100%;
            height: 100%;
            position: relative;
            overflow: hidden;
            border-radius: 24px;
        }

        .theme-card-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0;
            transition: opacity 0.8s ease, transform 0.6s ease;
            filter: url(#displacement-subtle);
        }

        .theme-card-image img.loaded {
            opacity: 1;
        }

        .theme-card:hover .theme-card-image img {
            transform: scale(1.05);
        }

        .theme-card-image::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(
                to bottom,
                transparent 0%,
                transparent 50%,
                rgba(10, 10, 10, 0.95) 100%
            );
            pointer-events: none;
        }

        .theme-card-content {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 2rem;
            z-index: 10;
            transform: translateZ(20px);
        }

        .theme-card h3 {
            font-size: 1.4rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: #ffffff;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.8);
            line-height: 1.3;
        }

        .theme-card p {
            color: rgba(255, 255, 255, 0.7);
            font-size: 0.95rem;
            text-shadow: 0 1px 5px rgba(0, 0, 0, 0.8);
        }

        /* Loading Animation */
        .skeleton {
            background: linear-gradient(
                135deg,
                rgba(26, 26, 26, 0.4) 0%,
                rgba(37, 37, 37, 0.6) 50%,
                rgba(26, 26, 26, 0.4) 100%
            );
            background-size: 200% 200%;
            animation: loading 2s ease-in-out infinite;
        }

        @keyframes loading {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }

        /* Deck positioning animations */
        @keyframes cardFloat {
            0%, 100% {
                transform: translateY(0px) translateZ(0px);
            }
            50% {
                transform: translateY(-10px) translateZ(10px);
            }
        }

        @keyframes cardRotateGentle {
            0%, 100% {
                transform: rotateZ(0deg);
            }
            50% {
                transform: rotateZ(1deg);
            }
        }

        /* Loading spinner for infinite scroll */
        .loading-indicator {
            text-align: center;
            padding: 3rem 0;
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        .loading-spinner {
            display: inline-block;
            width: 24px;
            height: 24px;
            border: 3px solid rgba(255, 255, 255, 0.1);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Modal for Full-size Screenshots */
        .modal {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.95);
            z-index: 1000;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            flex-direction: column;
        }

        .modal.active {
            display: flex;
        }

        .modal-header {
            width: 100%;
            max-width: 90vw;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }

        .modal-title {
            font-size: 1.5rem;
            font-weight: 600;
        }

        .modal-close {
            background: none;
            border: none;
            color: var(--text-primary);
            font-size: 2rem;
            cursor: pointer;
            padding: 0.5rem;
            transition: transform 0.2s;
        }

        .modal-close:hover {
            transform: scale(1.1);
        }

        .modal-content {
            max-width: 90vw;
            max-height: 75vh;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modal-content img {
            max-width: 100%;
            max-height: 75vh;
            border-radius: 0.5rem;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
        }

        .modal-nav {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(0, 0, 0, 0.5);
            border: none;
            color: var(--text-primary);
            font-size: 2rem;
            padding: 1rem;
            cursor: pointer;
            border-radius: 0.5rem;
            transition: background 0.2s;
            z-index: 10;
        }

        .modal-nav:hover {
            background: rgba(0, 0, 0, 0.8);
        }

        .modal-nav.prev {
            left: 1rem;
        }

        .modal-nav.next {
            right: 1rem;
        }

        .modal-nav:disabled {
            opacity: 0.3;
            cursor: not-allowed;
        }

        .modal-footer {
            margin-top: 1rem;
            display: flex;
            gap: 0.5rem;
            align-items: center;
        }

        .screenshot-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.3);
            cursor: pointer;
            transition: all 0.2s;
        }

        .screenshot-dot.active {
            background: var(--accent);
            transform: scale(1.3);
        }

        .screenshot-dot:hover {
            background: rgba(255, 255, 255, 0.6);
        }

        /* Features Section */
        .features {
            padding: 6rem 0;
            background: var(--bg-secondary);
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 3rem;
        }

        .feature {
            text-align: center;
        }

        .feature h3 {
            font-size: 1.5rem;
            margin-bottom: 1rem;
        }

        .feature p {
            color: var(--text-secondary);
        }

        /* Footer */
        footer {
            padding: 3rem 0;
            text-align: center;
            color: var(--text-secondary);
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }

        /* Responsive */
        @media (max-width: 1200px) {
            .theme-card {
                width: 420px;
                height: 280px;
            }

            .gallery-grid {
                height: 700px;
            }
        }

        @media (max-width: 768px) {
            nav ul {
                gap: 1rem;
                font-size: 0.9rem;
            }

            .theme-card {
                width: 320px;
                height: 220px;
            }

            .gallery-grid {
                height: 600px;
            }

            .theme-card h3 {
                font-size: 1.1rem;
            }

            .theme-card-content {
                padding: 1.2rem;
            }

            .gallery h2 {
                margin-bottom: 4rem;
            }
        }

        @media (max-width: 480px) {
            .theme-card {
                width: 280px;
                height: 200px;
            }

            .gallery-grid {
                height: 500px;
            }

            .theme-card-content {
                padding: 1rem;
            }

            .theme-card h3 {
                font-size: 1rem;
            }

            .theme-card p {
                font-size: 0.85rem;
            }
        }
    </style>
</head>
<body>
    <!-- WebGL Background -->
    <canvas id="webgl-canvas"></canvas>

    <!-- Header -->
    <header>
        <div class="container">
            <div class="logo">Xela Themes</div>
            <nav>
                <ul>
                    <li><a href="#themes">Themes</a></li>
                    <li><a href="#features">Features</a></li>
                    <li><a href="https://github.com/cybrdelic/xela-themes">GitHub</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="hero">
        <div class="container">
            <h1>Xela Themes</h1>
            <p>Professional VS Code themes crafted for developers who care about aesthetics and functionality.</p>
            <a href="#themes" class="cta-button">Explore Themes</a>
        </div>
    </section>

    <!-- SVG Displacement Filters -->
    <svg class="svg-filters">
        <defs>
            <!-- Subtle wave displacement for loaded images -->
            <filter id="displacement-subtle">
                <feTurbulence type="fractalNoise" baseFrequency="0.01 0.02" numOctaves="3" seed="2" result="turbulence">
                    <animate attributeName="baseFrequency" values="0.01 0.02;0.015 0.025;0.01 0.02" dur="8s" repeatCount="indefinite"/>
                </feTurbulence>
                <feDisplacementMap in="SourceGraphic" in2="turbulence" scale="8" xChannelSelector="R" yChannelSelector="G"/>
            </filter>

            <!-- Wave displacement for cards -->
            <filter id="displacement-wave">
                <feTurbulence type="fractalNoise" baseFrequency="0.008 0.012" numOctaves="4" seed="1" result="turbulence">
                    <animate attributeName="baseFrequency" values="0.008 0.012;0.012 0.016;0.008 0.012" dur="12s" repeatCount="indefinite"/>
                    <animate attributeName="seed" values="1;50;1" dur="20s" repeatCount="indefinite"/>
                </feTurbulence>
                <feDisplacementMap in="SourceGraphic" in2="turbulence" scale="4" xChannelSelector="R" yChannelSelector="G"/>
            </filter>

            <!-- Intense displacement on hover -->
            <filter id="displacement-wave-intense">
                <feTurbulence type="fractalNoise" baseFrequency="0.015 0.02" numOctaves="5" seed="10" result="turbulence">
                    <animate attributeName="baseFrequency" values="0.015 0.02;0.025 0.03;0.015 0.02" dur="6s" repeatCount="indefinite"/>
                    <animate attributeName="seed" values="10;100;10" dur="10s" repeatCount="indefinite"/>
                </feTurbulence>
                <feDisplacementMap in="SourceGraphic" in2="turbulence" scale="12" xChannelSelector="R" yChannelSelector="G"/>
                <feGaussianBlur stdDeviation="0.5"/>
            </filter>

            <!-- Liquid distortion -->
            <filter id="displacement-liquid">
                <feTurbulence type="turbulence" baseFrequency="0.02 0.03" numOctaves="3" seed="5" result="turbulence">
                    <animate attributeName="baseFrequency" values="0.02 0.03;0.03 0.04;0.02 0.03" dur="10s" repeatCount="indefinite"/>
                </feTurbulence>
                <feDisplacementMap in="SourceGraphic" in2="turbulence" scale="15" xChannelSelector="R" yChannelSelector="B"/>
            </filter>
        </defs>
    </svg>

    <!-- Gallery Section -->
    <section class="gallery" id="themes">
        <div class="container">
            <h2>Theme Collection</h2>
            <div class="gallery-grid" id="gallery-grid">
                <!-- Dynamically populated with isometric card deck -->
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="features" id="features">
        <div class="container">
            <h2 style="text-align: center; margin-bottom: 4rem;">Features</h2>
            <div class="features-grid">
                <div class="feature">
                    <h3>Carefully Crafted</h3>
                    <p>Each theme is designed with attention to detail for optimal readability and visual appeal.</p>
                </div>
                <div class="feature">
                    <h3>Wide Selection</h3>
                    <p>From dark to light, minimal to vibrant - find the perfect theme for your workflow.</p>
                </div>
                <div class="feature">
                    <h3>Syntax Optimized</h3>
                    <p>Thoughtful color choices that make code structure clear and reduce eye strain.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="container">
            <p>&copy; 2025 Xela Themes. MIT Licensed.</p>
        </div>
    </footer>

    <!-- Modal for Full-size Screenshots -->
    <div class="modal" id="modal">
        <div class="modal-header">
            <div class="modal-title" id="modal-title"></div>
            <button class="modal-close" id="modal-close">&times;</button>
        </div>
        <div class="modal-content">
            <button class="modal-nav prev" id="modal-prev">‹</button>
            <img id="modal-image" src="" alt="">
            <button class="modal-nav next" id="modal-next">›</button>
        </div>
        <div class="modal-footer" id="modal-footer"></div>
    </div>

    <script>
        // WebGL Background Animation
        class WebGLBackground {
            constructor(canvas) {
                this.canvas = canvas;
                this.gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');

                if (!this.gl) {
                    console.warn('WebGL not supported');
                    return;
                }

                this.resize();
                window.addEventListener('resize', () => this.resize());

                this.init();
                this.animate();
            }

            resize() {
                this.canvas.width = window.innerWidth;
                this.canvas.height = window.innerHeight;
                if (this.gl) {
                    this.gl.viewport(0, 0, this.canvas.width, this.canvas.height);
                }
            }

            init() {
                const gl = this.gl;

                const vertexShader = this.createShader(gl.VERTEX_SHADER, `
                    attribute vec2 position;
                    void main() {
                        gl_Position = vec4(position, 0.0, 1.0);
                    }
                `);

                const fragmentShader = this.createShader(gl.FRAGMENT_SHADER, `
                    precision mediump float;
                    uniform float time;
                    uniform vec2 resolution;

                    void main() {
                        vec2 uv = gl_FragCoord.xy / resolution;
                        vec3 color = vec3(0.0);

                        // Animated gradient
                        float pattern = sin(uv.x * 10.0 + time * 0.5) *
                                      cos(uv.y * 10.0 + time * 0.3) * 0.5 + 0.5;

                        color = vec3(pattern * 0.1, pattern * 0.3, pattern * 0.2);

                        gl_FragColor = vec4(color, 1.0);
                    }
                `);

                this.program = this.createProgram(vertexShader, fragmentShader);
                gl.useProgram(this.program);

                const vertices = new Float32Array([
                    -1, -1,
                     1, -1,
                    -1,  1,
                     1,  1
                ]);

                const buffer = gl.createBuffer();
                gl.bindBuffer(gl.ARRAY_BUFFER, buffer);
                gl.bufferData(gl.ARRAY_BUFFER, vertices, gl.STATIC_DRAW);

                const position = gl.getAttribLocation(this.program, 'position');
                gl.enableVertexAttribArray(position);
                gl.vertexAttribPointer(position, 2, gl.FLOAT, false, 0, 0);

                this.timeUniform = gl.getUniformLocation(this.program, 'time');
                this.resolutionUniform = gl.getUniformLocation(this.program, 'resolution');

                this.startTime = Date.now();
            }

            createShader(type, source) {
                const gl = this.gl;
                const shader = gl.createShader(type);
                gl.shaderSource(shader, source);
                gl.compileShader(shader);

                if (!gl.getShaderParameter(shader, gl.COMPILE_STATUS)) {
                    console.error('Shader compile error:', gl.getShaderInfoLog(shader));
                    gl.deleteShader(shader);
                    return null;
                }

                return shader;
            }

            createProgram(vertexShader, fragmentShader) {
                const gl = this.gl;
                const program = gl.createProgram();
                gl.attachShader(program, vertexShader);
                gl.attachShader(program, fragmentShader);
                gl.linkProgram(program);

                if (!gl.getProgramParameter(program, gl.LINK_STATUS)) {
                    console.error('Program link error:', gl.getProgramInfoLog(program));
                    gl.deleteProgram(program);
                    return null;
                }

                return program;
            }

            animate() {
                const gl = this.gl;
                const time = (Date.now() - this.startTime) * 0.001;

                gl.uniform1f(this.timeUniform, time);
                gl.uniform2f(this.resolutionUniform, this.canvas.width, this.canvas.height);

                gl.clearColor(0.0, 0.0, 0.0, 1.0);
                gl.clear(gl.COLOR_BUFFER_BIT);
                gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);

                requestAnimationFrame(() => this.animate());
            }
        }

        // Initialize WebGL
        const canvas = document.getElementById('webgl-canvas');
        new WebGLBackground(canvas);

        // Image Lazy Loading with Intersection Observer
        class ImageLoader {
            constructor() {
                this.observer = new IntersectionObserver(
                    (entries) => this.handleIntersection(entries),
                    { rootMargin: '50px' }
                );
            }

            observe(img) {
                this.observer.observe(img);
            }

            handleIntersection(entries) {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const img = entry.target;
                        this.loadImage(img);
                        this.observer.unobserve(img);
                    }
                });
            }

            loadImage(img) {
                const src = img.dataset.src;
                if (!src) return;

                img.src = src;
                img.onload = () => {
                    img.classList.add('loaded');
                };
            }
        }

        // Theme Gallery Manager - Isometric Card Deck
        class GalleryManager {
            constructor() {
                this.grid = document.getElementById('gallery-grid');
                this.modal = document.getElementById('modal');
                this.modalImage = document.getElementById('modal-image');
                this.modalTitle = document.getElementById('modal-title');
                this.modalClose = document.getElementById('modal-close');
                this.modalPrev = document.getElementById('modal-prev');
                this.modalNext = document.getElementById('modal-next');
                this.modalFooter = document.getElementById('modal-footer');
                this.imageLoader = new ImageLoader();

                this.currentTheme = null;
                this.currentIndex = 0;
                this.allThemes = [];
                this.renderedCount = 0;
                this.batchSize = 20; // Cards per deck batch
                this.isLoading = false;

                // Isometric deck configuration
                this.deckConfig = {
                    centerX: 0,
                    centerY: 0,
                    mouseX: 0,
                    mouseY: 0,
                    rotationX: -15, // Isometric tilt
                    rotationY: 0,
                    spreadRadius: 600, // How far cards spread
                    stackOffset: 8 // Vertical stacking offset
                };

                this.cards = [];
                this.setupModal();
                this.setupMouseTracking();
                this.setupInfiniteScroll();
                this.loadThemes();
                this.startAnimationLoop();
            }

            setupMouseTracking() {
                // Track mouse for parallax/interaction
                let ticking = false;

                document.addEventListener('mousemove', (e) => {
                    if (!ticking) {
                        window.requestAnimationFrame(() => {
                            this.updateMousePosition(e);
                            ticking = false;
                        });
                        ticking = true;
                    }
                });

                // Update center position on window resize
                window.addEventListener('resize', () => {
                    this.updateCenterPosition();
                });

                this.updateCenterPosition();
            }

            updateCenterPosition() {
                const rect = this.grid.getBoundingClientRect();
                this.deckConfig.centerX = rect.left + rect.width / 2;
                this.deckConfig.centerY = rect.top + rect.height / 2;
            }

            updateMousePosition(e) {
                const dx = (e.clientX - this.deckConfig.centerX) / window.innerWidth;
                const dy = (e.clientY - this.deckConfig.centerY) / window.innerHeight;

                this.deckConfig.mouseX = dx;
                this.deckConfig.mouseY = dy;

                // Subtle rotation based on mouse
                this.deckConfig.rotationY = dx * 10;
                this.deckConfig.rotationX = -15 + dy * 5;
            }

            startAnimationLoop() {
                const animate = () => {
                    this.updateCardPositions();
                    requestAnimationFrame(animate);
                };
                animate();
            }

            setupInfiniteScroll() {
                // Create a sentinel below the gallery for infinite scroll
                const sentinel = document.createElement('div');
                sentinel.id = 'sentinel';
                sentinel.style.cssText = 'height: 1px; margin-top: 100vh;';
                this.grid.parentElement.appendChild(sentinel);

                const observer = new IntersectionObserver((entries) => {
                    if (entries[0].isIntersecting && !this.isLoading && this.renderedCount < this.allThemes.length) {
                        console.log('Loading more cards into deck...');
                        this.renderNextBatch();
                    }
                }, { rootMargin: '400px' });

                observer.observe(sentinel);

                // Also load more when scrolling near the last cards
                let scrollTimeout;
                window.addEventListener('scroll', () => {
                    clearTimeout(scrollTimeout);
                    scrollTimeout = setTimeout(() => {
                        const scrollPercentage = (window.scrollY + window.innerHeight) / document.documentElement.scrollHeight;
                        if (scrollPercentage > 0.7 && !this.isLoading && this.renderedCount < this.allThemes.length) {
                            this.renderNextBatch();
                        }
                    }, 100);
                });
            }

            setupModal() {
                this.modalClose.addEventListener('click', () => this.closeModal());
                this.modal.addEventListener('click', (e) => {
                    if (e.target === this.modal) this.closeModal();
                });

                this.modalPrev.addEventListener('click', (e) => {
                    e.stopPropagation();
                    this.navigateScreenshot(-1);
                });

                this.modalNext.addEventListener('click', (e) => {
                    e.stopPropagation();
                    this.navigateScreenshot(1);
                });

                document.addEventListener('keydown', (e) => {
                    if (!this.modal.classList.contains('active')) return;

                    if (e.key === 'Escape') this.closeModal();
                    if (e.key === 'ArrowLeft') this.navigateScreenshot(-1);
                    if (e.key === 'ArrowRight') this.navigateScreenshot(1);
                });
            }

            async loadThemes() {
                try {
                    const response = await fetch('/landing/themes-manifest.json');
                    const manifest = await response.json();

                    console.log(`Loaded ${manifest.count} themes from manifest`);

                    this.allThemes = manifest.themes;
                    this.renderNextBatch();
                } catch (error) {
                    console.error('Failed to load themes manifest:', error);
                    this.showError('Failed to load themes. Please refresh the page.');
                }
            }

            renderNextBatch() {
                if (this.isLoading || this.renderedCount >= this.allThemes.length) return;

                this.isLoading = true;
                const start = this.renderedCount;
                const end = Math.min(start + this.batchSize, this.allThemes.length);

                console.log(`Rendering deck batch: themes ${start + 1}-${end} of ${this.allThemes.length}`);

                // Stagger card creation for smooth entrance
                const renderBatch = () => {
                    const renderCard = (i) => {
                        if (i < end) {
                            this.createThemeCard(this.allThemes[i]);
                            setTimeout(() => renderCard(i + 1), 30); // Stagger by 30ms
                        } else {
                            this.renderedCount = end;
                            this.isLoading = false;
                            this.updateCenterPosition();
                        }
                    };
                    renderCard(start);
                };

                if ('requestIdleCallback' in window) {
                    requestIdleCallback(renderBatch, { timeout: 1000 });
                } else {
                    setTimeout(renderBatch, 0);
                }
            }

            showError(message) {
                const error = document.createElement('div');
                error.style.cssText = 'padding: 2rem; text-align: center; color: #ff4444;';
                error.textContent = message;
                this.grid.appendChild(error);
            }

            createThemeCard(theme) {
                const card = document.createElement('div');
                card.className = 'theme-card';
                card.dataset.themeId = theme.id;

                // Store card data for deck positioning
                const cardIndex = this.cards.length;
                const cardData = {
                    element: card,
                    index: cardIndex,
                    theme: theme,
                    angle: 0,
                    radius: 0,
                    targetX: 0,
                    targetY: 0,
                    targetZ: 0,
                    targetRotZ: 0,
                    currentX: 0,
                    currentY: 0,
                    currentZ: 0,
                    currentRotZ: 0,
                    hovered: false
                };

                this.cards.push(cardData);

                const imageContainer = document.createElement('div');
                imageContainer.className = 'theme-card-image skeleton';

                const img = document.createElement('img');
                img.dataset.src = theme.thumbnail;
                img.alt = theme.name;
                img.loading = 'lazy';
                img.decoding = 'async';

                img.onerror = () => {
                    imageContainer.classList.remove('skeleton');
                    imageContainer.innerHTML = `<div style="display: flex; align-items: center; justify-content: center; height: 100%; color: #666; font-size: 0.85rem;">Preview unavailable</div>`;
                };

                img.onload = () => {
                    imageContainer.classList.remove('skeleton');
                    img.classList.add('loaded');
                };

                imageContainer.appendChild(img);

                const content = document.createElement('div');
                content.className = 'theme-card-content';
                content.innerHTML = `
                    <h3>${theme.name}</h3>
                    <p>${theme.screenshotCount} screenshots</p>
                `;

                card.appendChild(imageContainer);
                card.appendChild(content);

                // Interaction handlers
                card.addEventListener('mouseenter', () => {
                    cardData.hovered = true;
                });

                card.addEventListener('mouseleave', () => {
                    cardData.hovered = false;
                });

                card.addEventListener('click', () => {
                    this.openModal(theme);
                });

                this.grid.appendChild(card);
                this.imageLoader.observe(img);

                // Calculate initial position
                this.calculateCardPosition(cardData);
            }

            calculateCardPosition(cardData) {
                const totalCards = this.cards.length;
                const cardsPerRing = 12;
                const ringIndex = Math.floor(cardData.index / cardsPerRing);
                const indexInRing = cardData.index % cardsPerRing;

                // Spiral deck layout
                const baseAngle = (indexInRing / cardsPerRing) * Math.PI * 2;
                const angleOffset = ringIndex * 0.3; // Rotate each ring slightly
                cardData.angle = baseAngle + angleOffset;

                // Radius increases with rings, creating expanding spiral
                cardData.radius = 200 + (ringIndex * 150);

                // Calculate positions in isometric space
                const spiralFactor = cardData.index * 0.15;
                cardData.targetX = Math.cos(cardData.angle + spiralFactor) * cardData.radius;
                cardData.targetY = Math.sin(cardData.angle + spiralFactor) * cardData.radius * 0.6; // Compressed Y for isometric
                cardData.targetZ = -cardData.index * this.deckConfig.stackOffset;
                cardData.targetRotZ = Math.sin(cardData.angle) * 3; // Subtle rotation variation

                // Initialize current positions for smooth interpolation
                cardData.currentX = cardData.targetX;
                cardData.currentY = cardData.targetY;
                cardData.currentZ = cardData.targetZ;
                cardData.currentRotZ = cardData.targetRotZ;
            }

            updateCardPositions() {
                this.cards.forEach((cardData, index) => {
                    // Smooth interpolation
                    const lerpFactor = cardData.hovered ? 0.15 : 0.08;

                    // Add mouse influence
                    const mouseInfluenceX = this.deckConfig.mouseX * 30;
                    const mouseInfluenceY = this.deckConfig.mouseY * 20;

                    // Hover expansion
                    const hoverScale = cardData.hovered ? 1.15 : 1.0;
                    const hoverZ = cardData.hovered ? 100 : 0;

                    // Lerp to target positions
                    cardData.currentX += (cardData.targetX + mouseInfluenceX - cardData.currentX) * lerpFactor;
                    cardData.currentY += (cardData.targetY + mouseInfluenceY - cardData.currentY) * lerpFactor;
                    cardData.currentZ += (cardData.targetZ + hoverZ - cardData.currentZ) * lerpFactor;
                    cardData.currentRotZ += (cardData.targetRotZ - cardData.currentRotZ) * lerpFactor;

                    // Add floating animation
                    const floatOffset = Math.sin(Date.now() * 0.001 + index * 0.5) * 5;
                    const rotateOffset = Math.cos(Date.now() * 0.0008 + index * 0.3) * 2;

                    // Apply transforms
                    const transform = `
                        translate(-50%, -50%)
                        translate(${cardData.currentX}px, ${cardData.currentY + floatOffset}px)
                        translateZ(${cardData.currentZ}px)
                        rotateX(${this.deckConfig.rotationX}deg)
                        rotateY(${this.deckConfig.rotationY}deg)
                        rotateZ(${cardData.currentRotZ + rotateOffset}deg)
                        scale(${hoverScale})
                    `;

                    cardData.element.style.transform = transform;
                    cardData.element.style.zIndex = Math.floor(1000 - cardData.currentZ);

                    // Initial positioning
                    if (cardData.element.style.left === '') {
                        cardData.element.style.left = '50%';
                        cardData.element.style.top = '50%';
                    }
                });
            }

            openModal(theme, index = 0) {
                this.currentTheme = theme;
                this.currentIndex = index;
                this.updateModalContent();
                this.modal.classList.add('active');
                document.body.style.overflow = 'hidden';
            }

            closeModal() {
                this.modal.classList.remove('active');
                document.body.style.overflow = '';
                this.currentTheme = null;
            }

            navigateScreenshot(delta) {
                if (!this.currentTheme) return;

                const newIndex = this.currentIndex + delta;
                if (newIndex >= 0 && newIndex < this.currentTheme.screenshots.length) {
                    this.currentIndex = newIndex;
                    this.updateModalContent();
                }
            }

            updateModalContent() {
                if (!this.currentTheme) return;

                const screenshot = this.currentTheme.screenshots[this.currentIndex];

                this.modalTitle.textContent = `${this.currentTheme.name} - ${screenshot.type}`;
                this.modalImage.src = screenshot.path;
                this.modalImage.alt = `${this.currentTheme.name} - ${screenshot.filename}`;

                // Update navigation buttons
                this.modalPrev.disabled = this.currentIndex === 0;
                this.modalNext.disabled = this.currentIndex === this.currentTheme.screenshots.length - 1;

                // Update dots
                this.modalFooter.innerHTML = '';
                this.currentTheme.screenshots.forEach((_, idx) => {
                    const dot = document.createElement('div');
                    dot.className = `screenshot-dot ${idx === this.currentIndex ? 'active' : ''}`;
                    dot.addEventListener('click', () => {
                        this.currentIndex = idx;
                        this.updateModalContent();
                    });
                    this.modalFooter.appendChild(dot);
                });
            }
        }

        // Initialize Gallery
        const gallery = new GalleryManager();

        // Smooth scroll for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                const href = this.getAttribute('href');
                if (href.startsWith('#')) {
                    e.preventDefault();
                    const target = document.querySelector(href);
                    if (target) {
                        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }
                }
            });
        });
    </script>
</body>
</html>
