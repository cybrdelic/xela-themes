{
  "name": "xela-themes",
  "displayName": "XELA Themes",
  "description": "A meticulously curated collection of 180+ high-quality XELA color themes for VS Code. Cleaned, optimized, and contrast-verified for professional coding environments.",
  "publisher": "cybrdelic",
  "version": "0.3.1",
  "type": "module",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/cybrdelic/xela-themes.git"
  },
  "keywords": [
    "theme",
    "themes",
    "color theme",
    "dark theme",
    "light theme",
    "xela",
    "amoled",
    "neon",
    "minimal",
    "aesthetic",
    "cyberpunk",
    "apple",
    "bauhaus",
    "brutalist"
  ],
  "galleryBanner": {
    "color": "#000000",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "configurationDefaults": {
      "[XELA Black]": {
        "editor.formatOnSave": true,
        "editor.formatOnSaveMode": "modificationsIfAvailable",
        "editor.codeActionsOnSave": {
          "source.organizeImports": "always",
          "source.fixAll": "always",
          "source.fixAll.eslint": "explicit",
          "source.fixAll.ruff": "explicit"
        },
        "typescript.updateImportsOnFileMove.enabled": "always",
        "javascript.updateImportsOnFileMove.enabled": "always",
        "typescript.tsserver.maxTsServerMemory": 6144,
        "typescript.tsserver.useSeparateSyntaxServer": true,
        "typescript.disableAutomaticTypeAcquisition": true,
        "typescript.preferences.importModuleSpecifier": "shortest",
        "javascript.preferences.importModuleSpecifier": "shortest",
        "javascript.format.enable": false,
        "editor.stickyScroll.enabled": true,
        "editor.stickyScroll.maxLineCount": 6,
        "editor.guides.bracketPairs": true,
        "editor.guides.indentation": true,
        "editor.renderLineHighlight": "all",
        "editor.cursorBlinking": "smooth",
        "editor.cursorSmoothCaretAnimation": "on",
        "editor.smoothScrolling": true,
        "editor.minimap.enabled": true,
        "editor.minimap.renderCharacters": false,
        "editor.minimap.showSlider": "always",
        "editor.rulers": [
          100,
          120
        ],
        "editor.hover.delay": 120,
        "editor.foldingImportsByDefault": true,
        "editor.inlineSuggest.enabled": true,
        "editor.suggest.insertMode": "replace",
        "editor.suggest.localityBonus": true,
        "editor.suggestSelection": "recentlyUsedByPrefix",
        "editor.snippetSuggestions": "inline",
        "editor.gotoLocation.multipleDefinitions": "peek",
        "editor.gotoLocation.multipleReferences": "peek",
        "editor.inlayHints.enabled": "on",
        "editor.inlayHints.padding": true,
        "breadcrumbs.enabled": true,
        "workbench.editor.enablePreview": false,
        "workbench.editor.wrapTabs": true,
        "workbench.tree.indent": 14,
        "diffEditor.hideUnchangedRegions.enabled": true,
        "git.autofetch": true,
        "scm.defaultViewMode": "tree",
        "problems.sortOrder": "severity",
        "files.eol": "\n",
        "files.insertFinalNewline": true,
        "files.trimFinalNewlines": true,
        "files.trimTrailingWhitespace": true,
        "terminal.integrated.defaultLocation": "editor",
        "terminal.integrated.scrollback": 40000
      }
    },
