{
  "name": "xela-themes",
  "displayName": "XELA Themes",
  "description": "A curated collection of 200+ distinctive XELA color themes for VS Code, including Tech Nostalgia, Apple/Pro, and handpicked dark/light themes.",
  "publisher": "cybrdelic",
  "version": "0.3.4",
  "type": "module",
  "main": "./extension.js",
  "bin": {
    "xela-themes": "./bin/xela-themes.mjs"
  },
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/cybrdelic/xela-themes.git"
  },
  "keywords": [
    "theme",
    "themes",
    "color theme",
    "dark theme",
    "light theme",
    "xela",
    "amoled",
    "neon",
    "minimal",
    "aesthetic",
    "cyberpunk",
    "apple",
    "bauhaus",
    "brutalist"
  ],
  "galleryBanner": {
    "color": "#000000",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.86.0"
  },
  "scripts": {
    "lint": "eslint --ext .js src/ || true",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "test": "npm run test:smoke",
    "test:smoke": "npm run test:themes",
    "ci": "npm run lint && npm run test:all",
    "package": "npx @vscode/vsce package",
    "install:vsix": "powershell -NoProfile -Command \"$pkg = Get-ChildItem -Filter *.vsix | Sort-Object LastWriteTime -Descending | Select-Object -First 1; if($pkg){ code --install-extension $pkg.FullName --force } else { Write-Error 'No VSIX found' }\"",
    "package-and-install": "npm run package && npm run install:vsix",
    "build:themes": "node ./scripts/theme-system/build-themes.mjs && node ./scripts/auto-fix-themes.cjs",
    "build:windows-terminal": "node ./scripts/theme-system/build-windows-terminal.mjs",
    "build:windows-personalization": "npm run build:windows-terminal && node ./scripts/theme-system/build-windows-personalization.mjs",
    "build:extension": "node ./scripts/theme-system/build-extension.mjs",
    "build:browser-themes": "node ./scripts/theme-system/build-browser-themes.mjs",
    "windows-terminal:install": "node ./scripts/theme-system/install-windows-terminal.mjs",
    "windows-terminal:select": "node ./scripts/theme-system/select-windows-terminal-theme.mjs",
    "windows:apply": "node ./scripts/theme-system/install-windows-personalization.mjs",
    "icons:generate": "node ./scripts/theme-system/generate-icons.mjs",
    "icons:apply": "node ./scripts/theme-system/apply-icons.mjs",
    "icons:restore": "node ./scripts/theme-system/apply-icons.mjs --restore",
    "optimize:themes": "node ./scripts/optimize-themes.mjs",
    "test:themes": "node ./scripts/theme-system/test-build.mjs",
    "test:windows-terminal": "node ./scripts/theme-system/test-windows-terminal.mjs",
    "test:windows-terminal:install": "node ./scripts/theme-system/test-windows-terminal-install.mjs",
    "test:windows-personalization": "node ./scripts/theme-system/test-windows-personalization.mjs",
    "test:windows-personalization:install": "node ./scripts/theme-system/test-windows-personalization-install.mjs",
    "test:completeness": "node ./scripts/test-theme-completeness.cjs",
    "test:all": "npm run test:themes && npm run test:windows-terminal && npm run test:windows-personalization && npm run test:completeness && npm run a11y:audit",
    "fix:themes": "node ./scripts/auto-fix-themes.cjs",
    "a11y:audit": "node ./scripts/accessibility/run-accessibility.cjs audit",
    "a11y:audit:aaa": "node ./scripts/accessibility/run-accessibility.cjs audit --target-level AAA",
    "a11y:check": "node ./scripts/accessibility/run-accessibility.cjs check",
    "a11y:fix": "node ./scripts/accessibility/run-accessibility.cjs fix",
    "a11y:fix:all": "node ./scripts/accessibility/auto-fix.cjs",
    "a11y:fix:dry": "node ./scripts/accessibility/auto-fix.cjs --dry-run",
    "a11y:fuzz": "node ./scripts/accessibility/run-accessibility.cjs fuzz",
    "a11y:simulate": "node ./scripts/accessibility/run-accessibility.cjs simulate",
    "a11y:test": "node ./scripts/accessibility/test-accessibility.cjs",
    "update:package": "node ./scripts/theme-system/update-package-themes.mjs",
    "generate:manifest": "node scripts/generate-themes-manifest.js",
    "serve": "npm run generate:manifest && npx serve .",
    "build:test": "npm run build:themes && npm run test:smoke",
    "prepackage": "npm run build:themes && npm run update:package && npm run test:smoke",
    "rebuild": "npm run build:themes && npm run update:package && npm run package-and-install",
    "commit": "git add . && git commit -m",
    "push": "git push origin master",
    "quick": "git add . && git commit -m 'chore: quick save' && git push origin master",
    "release:tag": "node scripts/release-tag.js",
    "publish:force": "gh workflow run 'CI / Publish VS Code Extension' -f force_publish=true",
    "publish:dry": "gh workflow run publish.yml -f force_publish=true -f dry_run=true",
    "ci:dry": "node scripts/ci-trigger.js --dry",
    "ci:publish": "node scripts/ci-trigger.js --publish",
    "ci:logs": "node scripts/ci-trigger.js --logs",
    "capture:screens": "node scripts/theme-system/capture-theme-screenshots.mjs",
    "capture:vscode": "node scripts/theme-system/capture-theme-vscode.mjs"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.26.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^8.0.0",
    "eslint-plugin-node": "^11.0.0",
    "playwright": "^1.47.2",
    "prettier": "^2.0.0",
    "puppeteer": "^22.13.1"
  },
  "extensionDependencies": [
    "github.copilot-chat"
  ],
  "activationEvents": [
    "onCommand:xelaThemes.selectTheme",
    "onCommand:xelaThemes.openEditor",
    "onCommand:xelaThemes.fuzzTheme",
    "onCommand:xelaThemes.quickFuzz",
    "onCommand:xelaThemes.clearCustomizations",
    "onCommand:xelaThemes.clearFuzz"
  ],
  "categories": [
    "Themes"
  ],
  "contributes": {
    "commands": [
      {
        "command": "xelaThemes.selectTheme",
        "title": "XELA Themes: Select Theme Pack",
        "category": "XELA Themes"
      },
      {
        "command": "xelaThemes.openEditor",
        "title": "XELA Themes: Open Theme Editor",
        "category": "XELA Themes"
      },
      {
        "command": "xelaThemes.clearCustomizations",
        "title": "XELA Themes: Clear Theme Customizations",
        "category": "XELA Themes"
      },
      {
        "command": "xelaThemes.fuzzTheme",
        "title": "XELA Themes: Fuzz Theme (with Panel)",
        "category": "XELA Themes"
      },
      {
        "command": "xelaThemes.quickFuzz",
        "title": "XELA Themes: Quick Fuzz (Random Accessible Theme)",
        "category": "XELA Themes"
      },
      {
        "command": "xelaThemes.clearFuzz",
        "title": "XELA Themes: Clear Fuzzed Colors",
        "category": "XELA Themes"
      }
    ],
    "configurationDefaults": {
      "[XELA Black]": {
        "editor.formatOnSave": true,
        "editor.formatOnSaveMode": "modificationsIfAvailable",
        "editor.codeActionsOnSave": {
          "source.organizeImports": "always",
          "source.fixAll": "always",
          "source.fixAll.eslint": "explicit",
          "source.fixAll.ruff": "explicit"
        },
        "typescript.updateImportsOnFileMove.enabled": "always",
        "javascript.updateImportsOnFileMove.enabled": "always",
        "typescript.tsserver.maxTsServerMemory": 6144,
        "typescript.tsserver.useSeparateSyntaxServer": true,
        "typescript.disableAutomaticTypeAcquisition": true,
        "typescript.preferences.importModuleSpecifier": "shortest",
        "javascript.preferences.importModuleSpecifier": "shortest",
        "javascript.format.enable": false,
        "editor.stickyScroll.enabled": true,
        "editor.stickyScroll.maxLineCount": 6,
        "editor.guides.bracketPairs": true,
        "editor.guides.indentation": true,
        "editor.renderLineHighlight": "all",
        "editor.cursorBlinking": "smooth",
        "editor.cursorSmoothCaretAnimation": "on",
        "editor.smoothScrolling": true,
        "editor.minimap.enabled": true,
        "editor.minimap.renderCharacters": false,
        "editor.minimap.showSlider": "always",
        "editor.rulers": [
          100,
          120
        ],
        "editor.hover.delay": 120,
        "editor.foldingImportsByDefault": true,
        "editor.inlineSuggest.enabled": true,
        "editor.suggest.insertMode": "replace",
        "editor.suggest.localityBonus": true,
        "editor.suggestSelection": "recentlyUsedByPrefix",
        "editor.snippetSuggestions": "inline",
        "editor.gotoLocation.multipleDefinitions": "peek",
        "editor.gotoLocation.multipleReferences": "peek",
        "editor.inlayHints.enabled": "on",
        "editor.inlayHints.padding": true,
        "breadcrumbs.enabled": true,
        "workbench.editor.enablePreview": false,
        "workbench.editor.wrapTabs": true,
        "workbench.tree.indent": 14,
        "diffEditor.hideUnchangedRegions.enabled": true,
        "git.autofetch": true,
        "scm.defaultViewMode": "tree",
        "problems.sortOrder": "severity",
        "files.eol": "\n",
        "files.insertFinalNewline": true,
        "files.trimFinalNewlines": true,
        "files.trimTrailingWhitespace": true,
        "terminal.integrated.defaultLocation": "editor",
        "terminal.integrated.scrollback": 40000
      }
    },
