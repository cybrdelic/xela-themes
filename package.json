{
  "name": "xela-themes",
  "displayName": "XELA Themes",
  "description": "World-class VS Code theme extension boilerplate.",
  "publisher": "cybrdelic",
  "version": "0.1.5",
  "type": "module",
  "private": false,
  "main": "./extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/cybrdelic/xela-themes.git"
  },
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "commands": [
      {
        "command": "xela.showLogs",
        "title": "XELA: Show Logs",
        "category": "XELA"
      },
      {
        "command": "xela.applyPreset.globalAdditive",
        "title": "XELA: Apply Preset Globally (Additive, keep existing settings)",
        "category": "XELA"
      },
      {
        "command": "xela.applyPreset.globalOverwrite",
        "title": "XELA: Apply Preset Globally (Overwrite conflicts)",
        "category": "XELA"
      },
      {
        "command": "xela.applyPreset.additive",
        "title": "XELA: Apply Preset (Additive, keep existing settings)",
        "category": "XELA"
      },
      {
        "command": "xela.applyPreset.overwrite",
        "title": "XELA: Apply Preset (Overwrite conflicts)",
        "category": "XELA"
      },
      {
        "command": "xela.openPreset",
        "title": "XELA: Open Full Preset",
        "category": "XELA"
      },
      {
        "command": "xela.toggle.formatOnSave",
        "title": "XELA: Toggle Format on Save",
        "category": "XELA"
      },
      {
        "command": "xela.toggle.stickyScroll",
        "title": "XELA: Toggle Sticky Scroll",
        "category": "XELA"
      },
      {
        "command": "xela.toggle.bracketPairs",
        "title": "XELA: Toggle Bracket Pair Guides",
        "category": "XELA"
      },
      {
        "command": "xela.toggle.minimap",
        "title": "XELA: Toggle Minimap",
        "category": "XELA"
      },
      {
        "command": "xela.toggle.smoothScrolling",
        "title": "XELA: Toggle Smooth Scrolling",
        "category": "XELA"
      },
      {
        "command": "xela.toggle.cursorAnimation",
        "title": "XELA: Toggle Cursor Animation",
        "category": "XELA"
      },
      {
        "command": "xela.toggle.semanticHighlighting",
        "title": "XELA: Toggle Semantic Highlighting",
        "category": "XELA"
      },
      {
        "command": "xela.toggle.inlayHints",
        "title": "XELA: Toggle Inlay Hints",
        "category": "XELA"
      },
      {
        "command": "xela.toggle.preview",
        "title": "XELA: Toggle Preview Editors",
        "category": "XELA"
      },
      {
        "command": "xela.toggle.wrapTabs",
        "title": "XELA: Toggle Wrap Tabs",
        "category": "XELA"
      },
      {
        "command": "xela.toggle.breadcrumbs",
        "title": "XELA: Toggle Breadcrumbs",
        "category": "XELA"
      },
      {
        "command": "xela.toggle.organizeImports",
        "title": "XELA: Toggle Auto Organize Imports",
        "category": "XELA"
      },
      {
        "command": "xela.toggle.fixAll",
        "title": "XELA: Toggle Auto Fix All",
        "category": "XELA"
      },
      {
        "command": "xela.toggle.updateImportsOnMove",
        "title": "XELA: Toggle Auto Update Imports on File Move",
        "category": "XELA"
      },
      {
        "command": "xela.showConfigHistory",
        "title": "XELA: Show Configuration History",
        "category": "XELA"
      },
      {
        "command": "xela.clearConfigHistory",
        "title": "XELA: Clear Configuration History",
        "category": "XELA"
      }
    ],
    "configurationDefaults": {
      "[XELA Black]": {
        "editor.formatOnSave": true,
        "editor.formatOnSaveMode": "modificationsIfAvailable",
        "editor.codeActionsOnSave": {
          "source.organizeImports": "always",
          "source.fixAll": "always",
          "source.fixAll.eslint": "explicit",
          "source.fixAll.ruff": "explicit"
        },
        "typescript.updateImportsOnFileMove.enabled": "always",
        "javascript.updateImportsOnFileMove.enabled": "always",
        "typescript.tsserver.maxTsServerMemory": 6144,
        "typescript.tsserver.useSeparateSyntaxServer": true,
        "typescript.disableAutomaticTypeAcquisition": true,
        "typescript.preferences.importModuleSpecifier": "shortest",
        "javascript.preferences.importModuleSpecifier": "shortest",
        "javascript.format.enable": false,
        "editor.stickyScroll.enabled": true,
        "editor.stickyScroll.maxLineCount": 6,
        "editor.guides.bracketPairs": true,
        "editor.guides.indentation": true,
        "editor.renderLineHighlight": "all",
        "editor.cursorBlinking": "smooth",
        "editor.cursorSmoothCaretAnimation": "on",
        "editor.smoothScrolling": true,
        "editor.minimap.enabled": true,
        "editor.minimap.renderCharacters": false,
        "editor.minimap.showSlider": "always",
        "editor.rulers": [
          100,
          120
        ],
        "editor.hover.delay": 120,
        "editor.foldingImportsByDefault": true,
        "editor.inlineSuggest.enabled": true,
        "editor.suggest.insertMode": "replace",
        "editor.suggest.localityBonus": true,
        "editor.suggestSelection": "recentlyUsedByPrefix",
        "editor.snippetSuggestions": "inline",
        "editor.gotoLocation.multipleDefinitions": "peek",
        "editor.gotoLocation.multipleReferences": "peek",
        "editor.inlayHints.enabled": "on",
        "editor.inlayHints.padding": true,
        "breadcrumbs.enabled": true,
        "workbench.editor.enablePreview": false,
        "workbench.editor.wrapTabs": true,
        "workbench.tree.indent": 14,
        "diffEditor.hideUnchangedRegions.enabled": true,
        "git.autofetch": true,
        "scm.defaultViewMode": "tree",
        "problems.sortOrder": "severity",
        "files.eol": "\n",
        "files.insertFinalNewline": true,
        "files.trimFinalNewlines": true,
        "files.trimTrailingWhitespace": true,
        "terminal.integrated.defaultLocation": "editor",
        "terminal.integrated.scrollback": 40000
      }
    },
