  "tokenColors": [
      {
        "scope": ["comment", "punctuation.definition.comment"],
        "settings": {
          "foreground": "#007744"
        }
      },
      {
        "scope": ["keyword", "storage", "storage.type"],
        "settings": {
          "foreground": "#00FF7F",
          "fontStyle": "bold"
        }
      },
      {
        "scope": ["string", "constant.character"],
        "settings": {
          "foreground": "#00FFAA"
        }
      },
      {
        "scope": ["constant.numeric", "constant.language"],
        "settings": {
          "foreground": "#66FFE0"
        }
      },
      {
        "scope": ["entity.name.function", "support.function"],
        "settings": {
          "foreground": "#00FF7F"
        }
      },
      {
        "scope": ["variable", "meta.definition.variable"],
        "settings": {
          "foreground": "#00FF7F"
        }
      },
      {
        "scope": ["entity.name.type", "support.class"],
        "settings": {
          "foreground": "#00CCFF"
        }
      },
      {
        "scope": ["invalid", "invalid.illegal"],
        "settings": {
          "foreground": "#000000",
          "fontStyle": "bold"
        }
      },
      {
        "scope": "entity.name.tag.html",
        "settings": {
          "foreground": "#00FF7F",
          "fontStyle": "bold"
        }
      },
      {
        "scope": ["entity.other.attribute-name", "entity.other.attribute-name.html"],
        "settings": {
          "foreground": "#00CCFF"
        }
      },
      {
        "scope": "punctuation.definition.tag",
        "settings": {
          "foreground": "#00FFAA"
        }
      },
      {
        "scope": ["keyword.operator", "keyword.control"],
        "settings": {
          "foreground": "#00FF7F"
        }
      },
      {
        "scope": ["storage.modifier", "storage.type.function"],
        "settings": {
          "foreground": "#00FFAA"
        }
      },
      {
        "scope": ["support.variable.property", "variable.other.property"],
        "settings": {
          "foreground": "#00CC66"
        }
      },
      {
        "scope": "support.constant.property-value",
        "settings": {
          "foreground": "#66FFE0"
        }
      },
      {
        "scope": ["support.type.property-name", "support.type.builtin"],
        "settings": {
          "foreground": "#00CCFF"
        }
      },
      {
        "scope": ["entity.name.section", "markup.heading"],
        "settings": {
          "foreground": "#00FF7F",
          "fontStyle": "bold"
        }
      },
      {
        "scope": "markup.bold",
        "settings": {
          "foreground": "#00FFAA",
          "fontStyle": "bold"
        }
      },
      {
        "scope": "markup.italic",
        "settings": {
          "foreground": "#00FFAA",
          "fontStyle": "italic"
        }
      },
      {
        "scope": "markup.inline.raw",
        "settings": {
          "foreground": "#66FFE0"
        }
      },
      {
        "scope": ["meta.embedded", "punctuation.section.embedded"],
        "settings": {
          "foreground": "#FFCC00"
        }
      },
      {
        "scope": "constant.character.escape",
        "settings": {
          "foreground": "#33FFCC"
        }
      },
      {
        "scope": ["support.function.builtin", "support.function.console"],
        "settings": {
          "foreground": "#00FF7F"
        }
      },
      {
        "scope": "markup.fenced_code.block",
        "settings": {
          "foreground": "#00CCFF"
        }
      },
      {
        "scope": ["markup.list", "punctuation.definition.list"],
        "settings": {
          "foreground": "#00FF7F"
        }
      },
      {
