      }
    }
  ],
  "semanticTokenColors": {
    "operator": "#FF66FF",
    "function": "#66FFFF",
    "type": "#C1A6FF",
    "string": "#FF66B2",
    "number": "#FFFF66",
    "variable": "#EAD7FF",
    "property": "#EAD7FF",
    "enumMember": "#FFD166"
  }
}