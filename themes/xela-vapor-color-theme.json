{
  "$schema": "vscode://schemas/color-theme",
  "name": "XELA Vapor — Neon Retrowave",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "titleBar.activeBackground": "#1A0033",
    "titleBar.inactiveBackground": "#1A0033",
    "titleBar.activeForeground": "#EAD7FF",
    "titleBar.inactiveForeground": "#BDA6DB",
    "titleBar.border": "#2B0055",
    "activityBar.background": "#0D001A",
    "activityBar.foreground": "#F7E9FF",
    "activityBar.inactiveForeground": "#BDA6DB",
    "activityBar.activeBorder": "#FF00FF",
    "activityBarBadge.background": "#00FFFF",
    "activityBarBadge.foreground": "#001A1A",
    "sideBar.background": "#110026",
    "sideBar.foreground": "#EAD7FF",
    "sideBar.border": "#2B0055",
    "statusBar.background": "#0D001A",
    "statusBar.foreground": "#EAD7FF",
    "statusBar.border": "#2B0055",
    "panel.background": "#110026",
    "panel.border": "#2B0055",
    "editorGroupHeader.tabsBackground": "#110026",
    "tab.activeBackground": "#1A0033",
    "tab.inactiveBackground": "#110026",
    "tab.activeForeground": "#FFFFFF",
    "tab.inactiveForeground": "#C9B1E6",
    "tab.activeBorderTop": "#FF00FF",
    "editor.background": "#1A0033",
    "editor.foreground": "#EAD7FF",
    "editor.lineHighlightBackground": "#2B0055",
    "editor.selectionBackground": "#FF00FF33",
    "editor.inactiveSelectionBackground": "#00FFFF22",
    "editor.findMatchBackground": "#00000000",
    "editor.findMatchBorder": "#FF00FF",
    "editor.findMatchHighlightBackground": "#33003380",
    "editor.hoverHighlightBackground": "#001A1A80",
    "editorCursor.foreground": "#00FFFF",
    "editorIndentGuide.background1": "#2E0A52",
    "editorIndentGuide.activeBackground1": "#4C1485",
    "editorBracketHighlight.foreground1": "#FF00FF",
    "editorBracketHighlight.foreground2": "#00FFFF",
    "editorBracketHighlight.foreground3": "#FFB86C",
    "editorBracketPairGuide.activeBackground1": "#FF00FF55",
    "editorBracketPairGuide.activeBackground2": "#00FFFF55",
    "editorInlayHint.foreground": "#EAD7FF",
    "editorInlayHint.background": "#2B0055",
    "editorInlayHint.parameterForeground": "#FFD1FF",
    "editorInlayHint.typeForeground": "#B3F9FF",
    "list.activeSelectionBackground": "#24003F",
    "list.hoverBackground": "#1F0036",
    "quickInput.background": "#16002B",
    "input.background": "#16002B",
    "input.border": "#3A0073",
    "button.background": "#FF00FF",
    "button.hoverBackground": "#FF66FF",
    "badge.background": "#00FFFF",
    "badge.foreground": "#001A1A",
    "textLink.foreground": "#00FFFF",
    "textLink.activeForeground": "#66FFFF",
    "textPreformat.foreground": "#FFD1FF",
    "textBlockQuote.background": "#16002B",
    "textBlockQuote.border": "#3A0073",
    "textCodeBlock.background": "#120024",
    "textSeparator.foreground": "#3A0073",
    "terminal.background": "#1A0033",
    "terminal.foreground": "#EAD7FF",
    "terminalCursor.foreground": "#00FFFF",
    "terminal.ansiBlack": "#0D001A",
    "terminal.ansiRed": "#FF3366",
    "terminal.ansiGreen": "#00E5FF",
    "terminal.ansiYellow": "#FFB86C",
    "terminal.ansiBlue": "#9E6EFF",
    "terminal.ansiMagenta": "#FF00FF",
    "terminal.ansiCyan": "#00FFFF",
    "terminal.ansiWhite": "#F7F0FF",
    "terminal.ansiBrightBlack": "#4B2E66",
    "terminal.ansiBrightRed": "#FF5A87",
    "terminal.ansiBrightGreen": "#4CFFCA",
    "terminal.ansiBrightYellow": "#FFD166",
    "terminal.ansiBrightBlue": "#C1A6FF",
    "terminal.ansiBrightMagenta": "#FF66FF",
    "terminal.ansiBrightCyan": "#66FFFF",
    "terminal.ansiBrightWhite": "#FFFFFF"
  },
  "tokenColors": [
    {
      "scope": [
        "source",
        "meta.brace",
        "punctuation"
      ],
      "settings": {
        "foreground": "#EAD7FF"
      }
    },
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#BDA6DB"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FF66FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#66FFFF"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#FF66B2"
      }
    },
    {
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#FFFF66"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type"
      ],
      "settings": {
        "foreground": "#C1A6FF"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#4CFFCA"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFF0F5"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.1.markdown",
        "markup.heading.setext.1.markdown"
      ],
      "settings": {
        "foreground": "#66FFFF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.2.markdown",
        "markup.heading.setext.2.markdown"
      ],
      "settings": {
        "foreground": "#FF66FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.3.markdown"
      ],
      "settings": {
        "foreground": "#FFB86C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.4.markdown"
      ],
      "settings": {
        "foreground": "#C1A6FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.5.markdown"
      ],
      "settings": {
        "foreground": "#4CFFCA",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.6.markdown"
      ],
      "settings": {
        "foreground": "#BDA6DB",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold",
        "markup.bold.markdown"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "punctuation.definition.bold.markdown"
      ],
      "settings": {
        "foreground": "#FF66FF"
      }
    },
    {
      "scope": [
        "markup.italic",
        "markup.italic.markdown"
      ],
      "settings": {
        "foreground": "#C1A6FF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.definition.italic.markdown"
      ],
      "settings": {
        "foreground": "#BDA6DB"
      }
    },
    {
      "scope": [
        "markup.strikethrough",
        "markup.strike",
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#FF3366",
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": [
        "markup.underline",
        "markup.underline.link",
        "meta.link",
        "meta.link.inline",
        "meta.link.reference"
      ],
      "settings": {
        "foreground": "#00FFFF",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#EAD7FF"
      }
    },
    {
      "scope": [
        "string.other.link.description.markdown"
      ],
      "settings": {
        "foreground": "#C1A6FF"
      }
    },
    {
      "scope": [
        "constant.other.reference.link.markdown"
      ],
      "settings": {
        "foreground": "#BDA6DB"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.inline",
        "markup.inline.code",
        "markup.inline.raw.string.markdown",
        "markup.raw.inline.markdown"
      ],
      "settings": {
        "foreground": "#FFD1FF"
      }
    },
    {
      "scope": [
        "markup.fenced_code.block.markdown",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#FFD1FF"
      }
    },
    {
      "scope": [
        "punctuation.definition.raw.markdown",
        "punctuation.definition.fenced.markdown"
      ],
      "settings": {
        "foreground": "#3A0073"
      }
    },
    {
      "scope": [
        "markup.quote",
        "markup.quote.markdown"
      ],
      "settings": {
        "foreground": "#BDA6DB",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.definition.quote.begin.markdown"
      ],
      "settings": {
        "foreground": "#FF66FF"
      }
    },
    {
      "scope": [
        "meta.separator.markdown"
      ],
      "settings": {
        "foreground": "#3A0073"
      }
    },
    {
      "scope": [
        "markup.list",
        "markup.list.numbered",
        "markup.list.unnumbered"
      ],
      "settings": {
        "foreground": "#FFD166"
      }
    },
    {
      "scope": [
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#FFD166"
      }
    },
    {
      "scope": [
        "markup.table"
      ],
      "settings": {
        "foreground": "#C1A6FF"
      }
    },
    {
      "scope": [
        "markup.table.header"
      ],
      "settings": {
        "foreground": "#66FFFF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "punctuation.definition.table.markdown",
        "meta.table.separator.markdown"
      ],
      "settings": {
        "foreground": "#3A0073"
      }
    },
    {
      "scope": [
        "meta.embedded.block.frontmatter",
        "punctuation.definition.metadata.markdown"
      ],
      "settings": {
        "foreground": "#9E8AB8"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#4CFFCA"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#FF3366"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#FFB86C"
      }
    },
    {
      "scope": [
        "markup.input.checkbox"
      ],
      "settings": {
        "foreground": "#00FFFF"
      }
    },
    {
      "scope": [
        "meta.image.inline",
        "meta.image.reference"
      ],
      "settings": {
        "foreground": "#00FFFF"
      }
    },
    {
      "scope": [
        "entity.name.tag.html",
        "entity.name.tag.xml"
      ],
      "settings": {
        "foreground": "#F7B883",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.tag.structure.any.html",
        "entity.name.tag.block.any.html"
      ],
      "settings": {
        "foreground": "#FFD166",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.tag.inline.any.html"
      ],
      "settings": {
        "foreground": "#EADCB2"
      }
    },
    {
      "scope": [
        "entity.name.tag.script.html",
        "entity.name.tag.style.html"
      ],
      "settings": {
        "foreground": "#FF3CAC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.xml"
      ],
      "settings": {
        "foreground": "#EADCB2",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.class.html",
        "entity.other.attribute-name.class.css"
      ],
      "settings": {
        "foreground": "#C8B0FF",
        "fontStyle": "italic bold"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.id.html",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#4CFFCA",
        "fontStyle": "italic bold"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.style.html"
      ],
      "settings": {
        "foreground": "#FF8BDA",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.event.html"
      ],
      "settings": {
        "foreground": "#D8C8FF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string.quoted.double.html",
        "string.quoted.single.html"
      ],
      "settings": {
        "foreground": "#00F5A0"
      }
    },
    {
      "scope": [
        "meta.attribute-with-value.html string"
      ],
      "settings": {
        "foreground": "#98FF66"
      }
    },
    {
      "scope": [
        "punctuation.definition.tag.begin.html",
        "punctuation.definition.tag.end.html"
      ],
      "settings": {
        "foreground": "#A6AAB4"
      }
    },
    {
      "scope": [
        "punctuation.definition.tag.html",
        "punctuation.separator.key-value.html"
      ],
      "settings": {
        "foreground": "#8E93A6"
      }
    },
    {
      "scope": [
        "punctuation.definition.string.begin.html",
        "punctuation.definition.string.end.html"
      ],
      "settings": {
        "foreground": "#9AA0B4"
      }
    },
    {
      "scope": [
        "comment.block.html",
        "punctuation.definition.comment.html"
      ],
      "settings": {
        "foreground": "#8E93A6",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "constant.character.entity.html",
        "constant.character.entity.named.html"
      ],
      "settings": {
        "foreground": "#F2C97D",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "punctuation.definition.entity.html"
      ],
      "settings": {
        "foreground": "#FFD166"
      }
    },
    {
      "scope": [
        "meta.tag.sgml.doctype.html",
        "entity.name.tag.doctype.html"
      ],
      "settings": {
        "foreground": "#FF3CAC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "keyword.doctype.xml"
      ],
      "settings": {
        "foreground": "#FF3CAC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "source.css.embedded.html"
      ],
      "settings": {
        "foreground": "#E0CCFF"
      }
    },
    {
      "scope": [
        "meta.embedded.block.css"
      ],
      "settings": {
        "foreground": "#D7C7FF"
      }
    },
    {
      "scope": [
        "source.js.embedded.html",
        "source.javascript.embedded.html"
      ],
      "settings": {
        "foreground": "#F7B883"
      }
    },
    {
      "scope": [
        "meta.embedded.block.javascript"
      ],
      "settings": {
        "foreground": "#EADCB2"
      }
    },
    {
      "scope": [
        "entity.name.tag.form.html",
        "entity.name.tag.input.html",
        "entity.name.tag.button.html"
      ],
      "settings": {
        "foreground": "#79E49A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.form.html"
      ],
      "settings": {
        "foreground": "#98FF66",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.tag.table.html",
        "entity.name.tag.tr.html",
        "entity.name.tag.td.html",
        "entity.name.tag.th.html"
      ],
      "settings": {
        "foreground": "#4CFFCA",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.tag.img.html",
        "entity.name.tag.video.html",
        "entity.name.tag.audio.html"
      ],
      "settings": {
        "foreground": "#FFD166",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.tag.a.html"
      ],
      "settings": {
        "foreground": "#4CFFCA",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.href.html"
      ],
      "settings": {
        "foreground": "#00F5A0",
        "fontStyle": "italic bold"
      }
    },
    {
      "scope": [
        "entity.name.tag.header.html",
        "entity.name.tag.main.html",
        "entity.name.tag.footer.html",
        "entity.name.tag.nav.html",
        "entity.name.tag.aside.html",
        "entity.name.tag.section.html",
        "entity.name.tag.article.html",
        "entity.name.tag.figure.html",
        "entity.name.tag.figcaption.html"
