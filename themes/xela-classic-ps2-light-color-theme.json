  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7A9AB5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#5A9CC9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.modifier",
        "storage.type.function"
      ],
      "settings": {
        "foreground": "#5A9CC9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "constant",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#C64040"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#C64040"
      }
    },
    {
      "scope": [
        "constant.other.symbol",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#D4A76A"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#2E8B57"
      }
    },
    {
      "scope": "string.template",
      "settings": {
        "foreground": "#2E8B57"
      }
    },
    {
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#4A9E9E"
      }
    },
    {
