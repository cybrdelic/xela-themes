  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#8B0000",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "storage", "storage.type"],
      "settings": {
        "foreground": "#DC143C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["constant", "constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#DC143C"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#B22222"
      }
    },
    {
      "scope": ["variable", "variable.parameter"],
      "settings": {
        "foreground": "#B22222"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#DC143C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["entity.name.type", "support.class", "support.type"],
      "settings": {
        "foreground": "#DC143C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#DC143C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#B22222",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#DC143C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#DC143C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#B22222",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#FFFFFF",
        "fontStyle": "bold underline"
      }
    },
    {
      "scope": ["storage.modifier", "storage.type.function"],
      "settings": {
        "foreground": "#DC143C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#B22222"
      }
    },
    {
      "scope": ["meta.function-call", "support.function.console"],
      "settings": {
        "foreground": "#DC143C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["support.type.property-name"],
      "settings": {
        "foreground": "#8B0000"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#B22222"
      }
    },
    {
      "scope": ["punctuation.definition.parameters", "punctuation.section.group"],
      "settings": {
        "foreground": "#4A0000"
      }
    },
    {
      "scope": ["punctuation.separator", "punctuation.terminator"],
      "settings": {
        "foreground": "#2F0000"
      }
    },
    {
      "scope": ["entity.name.tag.html"],
      "settings": {
        "foreground": "#DC143C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["meta.tag"],
      "settings": {
        "foreground": "#B22222"
      }
    },
    {
      "scope": ["support.type.property-name.css"],
      "settings": {
        "foreground": "#8B0000"
      }
    },
    {
      "scope": ["markup.underline"],
      "settings": {
        "foreground": "#DC143C",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#B22222"
      }
    }
