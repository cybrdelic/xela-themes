  "semanticTokenColors": {
    "variable": "#B22222",
    "parameter": "#B22222",
    "property": "#B22222",
    "function": "#DC143C",
    "method": "#DC143C",
    "class": "#DC143C",
    "type": "#DC143C",
    "enum": "#DC143C",
    "enumMember": "#B22222",
    "string": "#B22222",
    "number": "#DC143C",
    "boolean": "#DC143C",
    "comment": "#8B0000"
  }
}
