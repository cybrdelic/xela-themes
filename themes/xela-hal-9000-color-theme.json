      ],
      "settings": {
        "foreground": "#B22222",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid"
      ],
      "settings": {
        "foreground": "#99BFE6",
        "fontStyle": "bold underline"
      }
    },
    {
      "scope": [
        "storage.modifier",
        "storage.type.function"
      ],
      "settings": {
        "foreground": "#DC143C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#B22222"
      }
    },
    {
      "scope": [
        "meta.function-call",
        "support.function.console"
      ],
      "settings": {
        "foreground": "#DC143C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#8B0000"
      }
    },
    {
      "scope": [
        "support.constant"
      ],
      "settings": {
        "foreground": "#B22222"
      }
    },
    {
      "scope": [
        "punctuation.definition.parameters",
        "punctuation.section.group"
      ],
      "settings": {
        "foreground": "#4A0000"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator"
