      "settings": {
        "foreground": "#DC143C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "meta.tag"
      ],
      "settings": {
        "foreground": "#B22222"
      }
    },
    {
      "scope": [
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#8B0000"
      }
    },
    {
      "scope": [
        "markup.underline"
      ],
      "settings": {
        "foreground": "#DC143C",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.list"
      ],
      "settings": {
        "foreground": "#B22222"
      }
    }
