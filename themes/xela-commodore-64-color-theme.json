  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#554A96",
        "fontStyle": "italic"
      },
      "peekView.border": "#6C5EB5",
      "quickInput.background": "#261D5C",
      "quickInput.foreground": "#9486DD"
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#6C5EB5",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#C060C8"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted"
      ],
      "settings": {
        "foreground": "#50F748"
      }
    },
    {
      "scope": [
        "variable",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#6C5EB5"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
