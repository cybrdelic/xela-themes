    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#7CD0E8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid"
      ],
      "settings": {
        "foreground": "#E04048",
        "fontStyle": "bold underline"
      }
    },
    {
      "scope": [
        "storage.modifier",
        "storage.type.function"
      ],
      "settings": {
        "foreground": "#6C5EB5",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#F0E068"
      }
    },
    {
      "scope": [
        "meta.function-call",
        "support.function.console"
      ],
      "settings": {
        "foreground": "#50F748",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#7CD0E8"
      }
    },
    {
      "scope": [
        "support.constant"
      ],
      "settings": {
        "foreground": "#C060C8"
      }
    },
    {
      "scope": [
        "punctuation.definition.parameters",
