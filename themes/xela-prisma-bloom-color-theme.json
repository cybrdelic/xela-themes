  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9D8CB8",
        "fontStyle": "italic"
      },
      "peekView.border": "#007ACC",
      "quickInput.background": "#0C0324",
      "quickInput.foreground": "#F6EFFF",
      "gitDecoration.addedResourceForeground": "#81b88b",
      "selection.background": "#FF6AD555",
      "focusBorder": "#FF6AD5"
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FF6AD5",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "keyword.control"
      ],
      "settings": {
        "foreground": "#B497FF"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#7CFFCB"
      }
    },
    {
      "scope": [
        "support.function"
      ],
      "settings": {
        "foreground": "#96D3FF"
      }
    },
    {
      "scope": [
        "entity.name.class",
        "support.class",
        "entity.name.type"
      ],
      "settings": {
        "foreground": "#B497FF"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#F6EFFF"
      }
    },
    {
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#C7B0F8"
      }
    },
    {
      "scope": [
        "constant",
        "constant.language"
      ],
      "settings": {
        "foreground": "#FFE577"
      }
    },
    {
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#B497FF"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#A8FFE0"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#FF6AD5"
      }
    },
    {
      "scope": [
        "support.constant",
        "support.variable"
      ],
      "settings": {
        "foreground": "#FFE577"
      }
    },
    {
      "scope": [
        "meta.decorator",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#FF97E5"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#7CFFCB"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.tag.html",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#FF6AD5",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext"
      ],
      "settings": {
        "foreground": "#FFE577"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#F6EFFF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#FF97E5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#F6EFFF",
        "background": "#12052E"
      }
    },
    {
      "scope": [
        "markup.list"
      ],
      "settings": {
        "foreground": "#FFE577"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#C7B0F8",
        "background": "#12052E"
      }
    },
    {
      "scope": [
        "constant.character.entity"
      ],
      "settings": {
        "foreground": "#96D3FF"
      }
    },
    {
      "scope": [
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#FF8CA8"
      }
    }
