        "foreground": "#00FFFF"
      }
    },
    {
      "scope": [
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#E9D2A5"
      }
    },
    {
      "scope": [
        "markup.underline"
      ],
      "settings": {
        "foreground": "#99BFE6",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.list"
      ],
      "settings": {
        "foreground": "#99BFE6"
      }
    }
