        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#00FFFF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid"
      ],
      "settings": {
        "foreground": "#FF0000",
        "fontStyle": "bold underline"
      }
    },
    {
      "scope": [
        "storage.modifier",
        "storage.type.function"
      ],
      "settings": {
        "foreground": "#00FFFF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#FFFF00"
      }
    },
    {
      "scope": [
        "meta.function-call",
        "support.function.console"
      ],
      "settings": {
        "foreground": "#00FFFF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#E9D2A5"
      }
    },
    {
      "scope": [
        "support.constant"
      ],
      "settings": {
        "foreground": "#00FF00"
      }
    },
    {
      "scope": [
        "punctuation.definition.parameters",
        "punctuation.section.group"
