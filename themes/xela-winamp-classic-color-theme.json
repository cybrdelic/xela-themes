  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#606060",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "storage", "storage.type"],
      "settings": {
        "foreground": "#00FF00",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["constant", "constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#00FF00"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#FFFF00"
      }
    },
    {
      "scope": ["variable", "variable.parameter"],
      "settings": {
        "foreground": "#C0C0C0"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#00FFFF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["entity.name.type", "support.class", "support.type"],
      "settings": {
        "foreground": "#00FF00",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#00FF00",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#00FF00",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#00FF00",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#00FF00",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#00FFFF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#FF0000",
        "fontStyle": "bold underline"
      }
    },
    {
      "scope": ["storage.modifier", "storage.type.function"],
      "settings": {
        "foreground": "#00FFFF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#FFFF00"
      }
    },
    {
      "scope": ["meta.function-call", "support.function.console"],
      "settings": {
        "foreground": "#00FFFF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["support.type.property-name"],
      "settings": {
        "foreground": "#808080"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#00FF00"
      }
    },
    {
      "scope": ["punctuation.definition.parameters", "punctuation.section.group"],
      "settings": {
        "foreground": "#808080"
      }
    },
    {
      "scope": ["punctuation.separator", "punctuation.terminator"],
      "settings": {
        "foreground": "#606060"
      }
    },
    {
      "scope": ["entity.name.tag.html"],
      "settings": {
        "foreground": "#00FFFF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["meta.tag"],
      "settings": {
        "foreground": "#00FFFF"
      }
    },
    {
      "scope": ["support.type.property-name.css"],
      "settings": {
        "foreground": "#808080"
      }
    },
    {
      "scope": ["markup.underline"],
      "settings": {
        "foreground": "#C0C0C0",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#C0C0C0"
      }
    }
  ],
  "semanticTokenColors": {
    "variable": "#C0C0C0",
    "parameter": "#A0A0A0",
    "property": "#C0C0C0",
    "function": "#00FFFF",
    "method": "#00FFFF",
    "class": "#00FF00",
    "type": "#00FF00",
    "enum": "#00FF00",
    "enumMember": "#00FF00",
    "string": "#FFFF00",
    "number": "#00FF00",
    "boolean": "#00FF00",
    "comment": "#606060"
  }
}
