  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": { "foreground": "#6F655A", "fontStyle": "italic" }
    },
    {
      "scope": ["keyword", "storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#5B3A1C", "fontStyle": "bold" }
    },
    {
      "scope": ["keyword.control", "keyword.operator", "punctuation.accessor"],
      "settings": { "foreground": "#1E5FA8" }
    },
    {
      "scope": ["constant", "variable.other.constant", "constant.language", "constant.numeric"],
      "settings": { "foreground": "#B13A2E" }
    },
    {
      "scope": ["string", "string.quoted", "string.template", "string.interpolated"],
      "settings": { "foreground": "#2E6B3A" }
    },
    {
      "scope": ["constant.character.escape", "constant.character.entity"],
      "settings": { "foreground": "#2A8F9C" }
    },
    {
      "scope": ["variable", "meta.definition.variable", "identifier"],
      "settings": { "foreground": "#1D1A14" }
    },
    {
      "scope": ["variable.parameter", "meta.function.parameters", "meta.function.parameter"],
      "settings": { "foreground": "#174B84" }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call", "support.function.console"],
      "settings": { "foreground": "#1E5FA8" }
    },
    {
      "scope": ["entity.name.type", "support.class", "support.type", "storage.type.class"],
      "settings": { "foreground": "#B77414", "fontStyle": "bold" }
    },
    {
      "scope": ["entity.name.namespace", "storage.type.namespace", "storage.type.interface"],
      "settings": { "foreground": "#174B84" }
    },
    {
      "scope": ["support.variable.property", "variable.other.property", "variable.other.member", "meta.property-name"],
      "settings": { "foreground": "#5C544A" }
    },
    {
      "scope": ["punctuation", "punctuation.separator", "punctuation.terminator"],
      "settings": { "foreground": "#7A6F63" }
    },
    {
      "scope": ["markup.heading"],
      "settings": { "foreground": "#5B3A1C", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "foreground": "#1D1A14", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "foreground": "#1D1A14", "fontStyle": "italic" }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code.block", "markup.raw.block"],
      "settings": { "foreground": "#174B84" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#B13A2E", "fontStyle": "bold underline" }
    }
  ],

  "semanticTokenColors": {
    "variable": "#1D1A14",
    "parameter": "#174B84",
    "property": "#5C544A",
    "function": "#1E5FA8",
    "method": "#1E5FA8",
    "class": "#B77414",
    "type": "#B77414",
    "enum": "#5B3A1C",
    "enumMember": "#B13A2E",
    "string": "#2E6B3A",
    "number": "#B13A2E",
    "boolean": "#B13A2E",
    "comment": "#6F655A",
    "keyword": "#5B3A1C"
  }
}
