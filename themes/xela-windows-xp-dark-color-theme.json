        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#E85757"
      }
    },
    {
      "scope": [
        "constant.other.symbol",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#EFC985"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#4AB371"
      }
    },
