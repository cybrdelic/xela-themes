  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7A9AB5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#7AB8E8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.modifier",
        "storage.type.function"
      ],
      "settings": {
        "foreground": "#7AB8E8",
        "fontStyle": "bold"
      }
    },
