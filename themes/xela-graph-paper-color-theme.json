    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#16A34A"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#DC2626"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#F59E0B"
      }
    },
    {
      "scope": [
        "markup.strikethrough"
