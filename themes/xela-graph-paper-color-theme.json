    {
      "scope": [
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#2563EB"
      }
    },
    {
      "scope": [
        "markup.table"
      ],
      "settings": {
        "foreground": "#111827"
      }
    },
    {
      "scope": [
        "markup.table.header"
      ],
      "settings": {
        "foreground": "#0F172A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "punctuation.definition.table.markdown",
        "meta.table.separator.markdown"
      ],
      "settings": {
        "foreground": "#E5E7EB"
      }
    },
    {
      "scope": [
        "meta.embedded.block.frontmatter",
