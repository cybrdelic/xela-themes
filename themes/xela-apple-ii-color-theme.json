      }
    },
    {
      "scope": [
        "meta.function-call",
        "support.function.console"
      ],
      "settings": {
        "foreground": "#33FF33",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#33FF33"
      }
    },
    {
      "scope": [
        "support.constant"
      ],
      "settings": {
        "foreground": "#33FF33"
      }
    },
    {
      "scope": [
        "punctuation.definition.parameters",
