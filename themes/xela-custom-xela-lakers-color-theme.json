        "support.class"
      ],
      "settings": {
        "foreground": "#36C6C6"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "punctuation"
      ],
      "settings": {
        "foreground": "#CFCFD6"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#F3EAF7"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag",
        "entity.name.tag.html",
        "entity.name.tag.xml"
      ],
      "settings": {
        "foreground": "#B99BFF"
      }
    },
    {
      "name": "Attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#FDB927"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#4DD0E1"
      }
    },
    {
      "name": "Self",
      "scope": [
        "variable.language.this",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#B99BFF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Interface",
      "scope": [
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#36C6C6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Import Export",
      "scope": [
        "keyword.control.import",
        "keyword.control.export"
      ],
      "settings": {
        "foreground": "#B99BFF"
      }
    },
    {
      "name": "JSON Property",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#F3EAF7"
      }
    },
    {
      "name": "CSS Selector",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#FDB927"
      }
    },
    {
      "name": "CSS Value",
      "scope": [
        "support.constant.property-value.css"
      ],
      "settings": {
        "foreground": "#4DD0E1"
      }
    },
    {
      "name": "Markdown Heading",
      "scope": [
        "markup.heading.markdown"
      ],
      "settings": {
        "foreground": "#B99BFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Code",
      "scope": [
        "markup.inline.raw.markdown"
      ],
      "settings": {
        "foreground": "#FFD589"
      }
