    "gitDecoration.conflictingResourceForeground": "#FF4D6D"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#A9A6B8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
