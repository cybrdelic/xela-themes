        "string.quoted"
      ],
      "settings": {
        "foreground": "#FFD589"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#4DD0E1"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#FDB927"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#F3EAF7"
      }
    },
    {
      "name": "Type",
