    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#22C55E"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#EF4444"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#F59E0B"
      }
    },
    {
      "scope": [
        "markup.input.checkbox"
