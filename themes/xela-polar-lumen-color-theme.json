  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6C7B93",
        "fontStyle": "italic"
      },
      "peekView.border": "#007ACC",
      "quickInput.background": "#0B1624",
      "quickInput.foreground": "#D7E6F5",
      "gitDecoration.addedResourceForeground": "#81b88b",
      "selection.background": "#4FD1C560",
