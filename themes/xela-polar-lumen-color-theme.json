    {
      "scope": [
        "markup.list"
      ],
      "settings": {
        "foreground": "#FFC15E"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#8CB7E7",
        "background": "#0E1B2E"
      }
    },
    {
      "scope": [
        "constant.character.entity"
      ],
      "settings": {
        "foreground": "#4FD1C5"
      }
    },
    {
      "scope": [
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#F05D5E"
      }
