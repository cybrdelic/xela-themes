{
  "$schema": "vscode://schemas/color-theme",
  "name": "XELA Deep — Abyssal Glow",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#001122",
    "editor.foreground": "#B0E0E6",
    "activityBar.background": "#000511",
    "sideBar.background": "#000A1A",
    "titleBar.activeBackground": "#00040D",
    "statusBar.background": "#00040D",
    "selection.background": "#00CED133",
    "focusBorder": "#40E0D0AA",
    "editor.lineHighlightBackground": "#001A33",
    "editor.selectionBackground": "#7FFFD422",
    "editorCursor.foreground": "#00CED1",
    "editorHoverWidget.background": "#00111F",
    "editorHoverWidget.border": "#00223E",
    "list.activeSelectionBackground": "#00162B",
    "list.highlightForeground": "#40E0D0",
    "terminal.ansiCyan": "#40E0D0",
    "terminal.ansiGreen": "#7FFFD4"
  },
  "tokenColors": [
    {
      "scope": [
        "keyword"
      ],
      "settings": {
        "foreground": "#00CED1",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#40E0D0"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#7FFFD4"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type"
      ],
      "settings": {
        "foreground": "#4682B4"
      }
    },
    {
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#FFD700"
      }
    },
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#5F9EA0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.1.markdown",
        "markup.heading.setext.1.markdown"
      ],
      "settings": {
        "foreground": "#40E0D0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.2.markdown",
        "markup.heading.setext.2.markdown"
      ],
      "settings": {
        "foreground": "#00CED1",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.3.markdown"
      ],
      "settings": {
        "foreground": "#7FFFD4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.4.markdown"
      ],
      "settings": {
        "foreground": "#4682B4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.5.markdown"
      ],
      "settings": {
        "foreground": "#FFD700",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.6.markdown"
      ],
      "settings": {
        "foreground": "#B0E0E6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold",
        "markup.bold.markdown"
      ],
      "settings": {
        "foreground": "#E6FFFF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "punctuation.definition.bold.markdown"
      ],
      "settings": {
        "foreground": "#40E0D0"
      }
    },
    {
      "scope": [
        "markup.italic",
        "markup.italic.markdown"
      ],
      "settings": {
        "foreground": "#7FFFD4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.definition.italic.markdown"
      ],
      "settings": {
        "foreground": "#00CED188"
      }
    },
    {
      "scope": [
        "markup.strikethrough",
        "markup.strike",
        "markup.deleted"
      ],
      "settings": {
        "fontStyle": "strikethrough",
        "foreground": "#80B3B3"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "markup.underline.link.markdown",
        "markup.link",
        "meta.link",
        "meta.link.inline",
        "meta.link.reference"
      ],
      "settings": {
        "foreground": "#40E0D0",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#E6FFFF"
      }
    },
    {
      "scope": [
        "string.other.link.description.markdown"
      ],
      "settings": {
        "foreground": "#7FFFD4"
      }
    },
    {
      "scope": [
        "constant.other.reference.link.markdown"
      ],
      "settings": {
        "foreground": "#5F9EA0"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.inline",
        "markup.inline.code",
        "markup.inline.raw.string.markdown",
        "markup.raw.inline.markdown"
      ],
      "settings": {
        "foreground": "#B0E0E6"
      }
    },
    {
      "scope": [
        "markup.fenced_code.block.markdown",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#B0E0E6"
      }
    },
    {
      "scope": [
        "punctuation.definition.raw.markdown",
        "punctuation.definition.fenced.markdown"
      ],
      "settings": {
        "foreground": "#00223E"
      }
    },
    {
      "scope": [
        "markup.quote",
        "markup.quote.markdown"
      ],
      "settings": {
        "foreground": "#80B3B3",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.definition.quote.begin.markdown"
      ],
      "settings": {
        "foreground": "#40E0D0"
      }
    },
    {
      "scope": [
        "meta.separator.markdown"
      ],
      "settings": {
        "foreground": "#00223E"
      }
    },
    {
      "scope": [
        "markup.list",
        "markup.list.numbered",
        "markup.list.unnumbered"
      ],
      "settings": {
        "foreground": "#E6FFFF"
      }
    },
    {
      "scope": [
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#FFD700"
      }
    },
    {
      "scope": [
        "markup.table"
      ],
      "settings": {
        "foreground": "#E6FFFF"
      }
    },
    {
      "scope": [
        "markup.table.header"
      ],
      "settings": {
        "foreground": "#40E0D0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "punctuation.definition.table.markdown",
        "meta.table.separator.markdown"
      ],
      "settings": {
        "foreground": "#00223E"
      }
    },
    {
      "scope": [
        "meta.embedded.block.frontmatter",
        "punctuation.definition.metadata.markdown"
      ],
      "settings": {
        "foreground": "#5F9EA0"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#66FF99"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#FF6666"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#FFD166"
      }
    },
    {
      "scope": [
        "markup.input.checkbox"
      ],
      "settings": {
        "foreground": "#40E0D0"
      }
    },
    {
      "scope": [
        "meta.image.inline",
        "meta.image.reference"
      ],
      "settings": {
        "foreground": "#40E0D0"
      }
    },
    {
      "scope": [
        "entity.name.tag.html",
        "entity.name.tag.xml"
      ],
      "settings": {
        "foreground": "#F7B883",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.tag.structure.any.html",
        "entity.name.tag.block.any.html"
      ],
      "settings": {
        "foreground": "#FFD166",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.tag.inline.any.html"
      ],
      "settings": {
        "foreground": "#EADCB2"
      }
    },
    {
      "scope": [
        "entity.name.tag.script.html",
        "entity.name.tag.style.html"
      ],
      "settings": {
        "foreground": "#FF3CAC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.xml"
      ],
      "settings": {
        "foreground": "#EADCB2",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.class.html",
        "entity.other.attribute-name.class.css"
      ],
      "settings": {
        "foreground": "#C8B0FF",
        "fontStyle": "italic bold"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.id.html",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#4CFFCA",
        "fontStyle": "italic bold"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.style.html"
      ],
      "settings": {
        "foreground": "#FF8BDA",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.event.html"
      ],
      "settings": {
        "foreground": "#D8C8FF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string.quoted.double.html",
        "string.quoted.single.html"
      ],
      "settings": {
        "foreground": "#00F5A0"
      }
    },
    {
      "scope": [
        "meta.attribute-with-value.html string"
      ],
      "settings": {
        "foreground": "#98FF66"
      }
    },
    {
      "scope": [
        "punctuation.definition.tag.begin.html",
        "punctuation.definition.tag.end.html"
      ],
      "settings": {
        "foreground": "#A6AAB4"
      }
    },
    {
      "scope": [
        "punctuation.definition.tag.html",
        "punctuation.separator.key-value.html"
      ],
      "settings": {
        "foreground": "#8E93A6"
      }
    },
    {
      "scope": [
        "punctuation.definition.string.begin.html",
        "punctuation.definition.string.end.html"
      ],
      "settings": {
        "foreground": "#9AA0B4"
      }
    },
    {
      "scope": [
        "comment.block.html",
        "punctuation.definition.comment.html"
      ],
      "settings": {
        "foreground": "#8E93A6",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "constant.character.entity.html",
        "constant.character.entity.named.html"
      ],
      "settings": {
        "foreground": "#F2C97D",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "punctuation.definition.entity.html"
      ],
      "settings": {
        "foreground": "#FFD166"
      }
    },
    {
      "scope": [
        "meta.tag.sgml.doctype.html",
        "entity.name.tag.doctype.html"
      ],
      "settings": {
        "foreground": "#FF3CAC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "keyword.doctype.xml"
      ],
      "settings": {
        "foreground": "#FF3CAC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "source.css.embedded.html"
      ],
      "settings": {
        "foreground": "#E0CCFF"
      }
    },
    {
      "scope": [
        "meta.embedded.block.css"
      ],
      "settings": {
        "foreground": "#D7C7FF"
      }
    },
    {
      "scope": [
        "source.js.embedded.html",
        "source.javascript.embedded.html"
      ],
      "settings": {
        "foreground": "#F7B883"
      }
    },
    {
      "scope": [
        "meta.embedded.block.javascript"
      ],
      "settings": {
        "foreground": "#EADCB2"
      }
    },
    {
      "scope": [
        "entity.name.tag.form.html",
        "entity.name.tag.input.html",
        "entity.name.tag.button.html"
      ],
      "settings": {
        "foreground": "#79E49A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.form.html"
      ],
      "settings": {
        "foreground": "#98FF66",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.tag.table.html",
        "entity.name.tag.tr.html",
        "entity.name.tag.td.html",
        "entity.name.tag.th.html"
      ],
      "settings": {
        "foreground": "#4CFFCA",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.tag.img.html",
        "entity.name.tag.video.html",
        "entity.name.tag.audio.html"
      ],
      "settings": {
        "foreground": "#FFD166",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.tag.a.html"
      ],
      "settings": {
        "foreground": "#4CFFCA",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.href.html"
      ],
      "settings": {
        "foreground": "#00F5A0",
        "fontStyle": "italic bold"
      }
    },
    {
      "scope": [
        "entity.name.tag.header.html",
        "entity.name.tag.main.html",
        "entity.name.tag.footer.html",
        "entity.name.tag.nav.html",
        "entity.name.tag.aside.html",
        "entity.name.tag.section.html",
        "entity.name.tag.article.html",
        "entity.name.tag.figure.html",
        "entity.name.tag.figcaption.html"
      ],
      "settings": {
        "foreground": "#C8B0FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "text.html.basic"
      ],
      "settings": {
        "foreground": "#F7F8FA"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#40E0D0",
    "type": "#4682B4",
    "string": "#7FFFD4",
    "number": "#FFD700",
    "keyword": "#00CED1"
  }
}