  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#909090",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#C679EC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.modifier",
        "storage.type.function"
      ],
      "settings": {
        "foreground": "#B399E6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "constant",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#FF4444"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#FF4444"
      }
    },
    {
      "scope": [
        "constant.other.symbol",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#FFBB00"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#00CC00"
      }
    },
    {
      "scope": "string.template",
      "settings": {
        "foreground": "#00CC00"
      }
    },
    {
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#00CCCC"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#B0E8E8"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameter"
      ],
      "settings": {
        "foreground": "#B0E8E8"
      }
    },
    {
      "scope": [
        "support.variable.property",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#B0E8E8"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#88BBFF",
        "fontStyle": "bold"
      }
    },
