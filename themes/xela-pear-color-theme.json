  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#86868B",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#AF52DE",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "keyword.control",
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#AF52DE"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#007AFF"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#1D1D1F"
      }
    },
    {
      "scope": [
        "constant",
        "constant.language",
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#FF9500"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted"
      ],
      "settings": {
        "foreground": "#34C759"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#5AC8FA"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#FF3B30"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#007AFF"
      }
    },
    {
      "scope": [
        "support.function",
        "support.constant"
      ],
      "settings": {
        "foreground": "#5AC8FA"
      }
    },
    {
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#86868B"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF3B30",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#007AFF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#007AFF",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#34C759"
      }
    },
    {
      "scope": [
        "entity.name.tag.html",
        "entity.name.tag.xml"
      ],
      "settings": {
        "foreground": "#FF2D55",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "meta.property-name",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#007AFF"
      }
    },
    {
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#FF9500"
      }
    }
  ],
  "semanticTokenColors": {
    "variable": "#1D1D1F",
    "variable.defaultLibrary": "#1D1D1F",
    "parameter": "#4B4B50",
    "property": "#1D1D1F",
    "function": "#007AFF",
    "method": "#007AFF",
    "function.defaultLibrary": "#007AFF",
    "method.defaultLibrary": "#007AFF",
    "class": "#5AC8FA",
    "type": "#5AC8FA",
    "interface": "#5AC8FA",
    "enum": "#5AC8FA",
    "enumMember": "#FF9500",
    "namespace": "#5AC8FA",
    "keyword": "#AF52DE",
    "modifier": "#AF52DE",
    "operator": "#AF52DE",
    "comment": "#86868B",
    "string": "#34C759",
    "number": "#FF9500",
    "regexp": "#FF3B30",
    "decorator": "#FF3B30",
    "label": "#FF3B30",
    "macro": "#FF3B30",
    "event": "#FF3B30",
    "typeParameter": "#AF52DE"
  },
  "xBaseName": "XELA Pear — Clean Minimal",
  "xPackLabel": "XELA Graphite Atelier"
