  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#999999",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#AA00AA",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.modifier",
        "storage.type.function"
      ],
      "settings": {
        "foreground": "#AA00AA",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "constant",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#DD0000"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#DD0000"
      }
    },
    {
      "scope": [
        "constant.other.symbol",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#FF6600"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#00AA00"
      }
    },
    {
      "scope": "string.template",
      "settings": {
        "foreground": "#00AA00"
      }
    },
    {
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#00AAAA"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameter"
      ],
      "settings": {
        "foreground": "#4A90E2"
      }
    },
    {
      "scope": [
        "support.variable.property",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#4A90E2"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#4A90E2",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "meta.function-call",
        "support.function.console"
      ],
      "settings": {
        "foreground": "#4A90E2"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#FF6600",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "support.type.property-name",
        "support.type.primitive"
      ],
      "settings": {
        "foreground": "#FF6600"
      }
    },
    {
      "scope": [
        "support.constant",
        "support.constant.property-value"
      ],
      "settings": {
        "foreground": "#DD0000"
      }
    },
    {
      "scope": [
        "storage.type.interface",
        "entity.name.namespace"
