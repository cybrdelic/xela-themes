{
  "$schema": "vscode://schemas/color-theme",
  "name": "XELA Phosphor Green — Monochrome CRT",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "focusBorder": "#00FF7FAA",
    "selection.background": "#00FF7F22",
    "titleBar.activeBackground": "#000000",
    "titleBar.inactiveBackground": "#000000",
    "titleBar.activeForeground": "#CCFFDD",
    "titleBar.inactiveForeground": "#88AA99",
    "titleBar.border": "#0F0F0F",
    "activityBar.background": "#000000",
    "activityBar.foreground": "#CCFFDD",
    "activityBar.activeBorder": "#00FF7F",
    "activityBar.border": "#0F0F0F",
    "sideBar.background": "#000000",
    "sideBar.foreground": "#B8FFCE",
    "sideBar.border": "#0F0F0F",
    "statusBar.background": "#000000",
    "statusBar.foreground": "#B8FFCE",
    "statusBar.border": "#0F0F0F",
    "panel.background": "#000000",
    "panel.border": "#0F0F0F",
    "editorGroupHeader.tabsBackground": "#000000",
    "editorGroupHeader.tabsBorder": "#0D0D0D",
    "tab.activeBackground": "#000000",
    "tab.inactiveBackground": "#000000",
    "tab.border": "#000000",
    "tab.activeForeground": "#CCFFDD",
    "tab.inactiveForeground": "#88AA99",
    "tab.activeBorderTop": "#00FF7F",
    "editor.background": "#000000",
    "editor.foreground": "#CCFFDD",
    "editor.lineHighlightBackground": "#0D0D0D",
    "editor.selectionBackground": "#00FF7F22",
    "editorCursor.foreground": "#00FF7F",
    "editorHoverWidget.background": "#00110A",
    "editorHoverWidget.border": "#0A3322",
    "editorWidget.background": "#00110A",
    "editorWidget.border": "#0A3322",
    "list.activeSelectionBackground": "#0A0A0A",
    "list.hoverBackground": "#0D0D0D",
    "button.background": "#00FF7F",
    "button.hoverBackground": "#33FF99",
    "button.foreground": "#00110A",
    "terminal.background": "#000000",
    "terminal.foreground": "#CCFFDD",
    "terminalCursor.foreground": "#00FF7F",
    "terminal.ansiBlack": "#000000",
    "terminal.ansiRed": "#00AA55",
    "terminal.ansiGreen": "#00FF7F",
    "terminal.ansiYellow": "#55FF99",
    "terminal.ansiBlue": "#88FFBB",
    "terminal.ansiMagenta": "#66FFAA",
    "terminal.ansiCyan": "#AAFFDD",
    "terminal.ansiWhite": "#EEFFFA",
    "terminal.ansiBrightBlack": "#335544",
    "terminal.ansiBrightRed": "#22CC77",
    "terminal.ansiBrightGreen": "#00FF7F",
    "terminal.ansiBrightYellow": "#88FFBB",
    "terminal.ansiBrightBlue": "#BBFFDD",
    "terminal.ansiBrightMagenta": "#99FFCC",
    "terminal.ansiBrightCyan": "#D6FFF0",
    "terminal.ansiBrightWhite": "#FFFFFF"
  },
  "tokenColors": [
    {
      "scope": [
        "keyword",
        "storage.type"
      ],
      "settings": {
        "foreground": "#00FF7F",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#88FFBB"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#55FF99"
      }
    },
    {
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#AAFFDD"
      }
    },
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#88AA99",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.1.markdown",
        "markup.heading.setext.1.markdown"
      ],
      "settings": {
        "foreground": "#BBFFDD",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.2.markdown",
        "markup.heading.setext.2.markdown"
      ],
      "settings": {
        "foreground": "#00FF7F",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.3.markdown"
      ],
      "settings": {
        "foreground": "#55FF99",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.4.markdown"
      ],
      "settings": {
        "foreground": "#88FFBB",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.5.markdown"
      ],
      "settings": {
        "foreground": "#66FFAA",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.6.markdown"
      ],
      "settings": {
        "foreground": "#CCFFDD",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold",
        "markup.bold.markdown"
      ],
      "settings": {
        "foreground": "#EEFFFA",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "punctuation.definition.bold.markdown"
      ],
      "settings": {
        "foreground": "#00FF7F"
      }
    },
    {
      "scope": [
        "markup.italic",
        "markup.italic.markdown"
      ],
      "settings": {
        "foreground": "#CCFFDD",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.definition.italic.markdown"
      ],
      "settings": {
        "foreground": "#88AA99"
      }
    },
    {
      "scope": [
        "markup.strikethrough",
        "markup.strike",
        "markup.deleted"
      ],
      "settings": {
        "fontStyle": "strikethrough",
        "foreground": "#22CC77"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "markup.underline.link.markdown",
        "markup.link",
        "meta.link",
        "meta.link.inline",
        "meta.link.reference"
      ],
      "settings": {
        "foreground": "#88FFBB",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#EEFFFA"
      }
    },
    {
      "scope": [
        "string.other.link.description.markdown"
      ],
      "settings": {
        "foreground": "#BBFFDD"
      }
    },
    {
      "scope": [
        "constant.other.reference.link.markdown"
      ],
      "settings": {
        "foreground": "#88AA99"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.inline",
        "markup.inline.code",
        "markup.inline.raw.string.markdown",
        "markup.raw.inline.markdown"
      ],
      "settings": {
        "foreground": "#55FF99"
      }
    },
    {
      "scope": [
        "markup.fenced_code.block.markdown",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#55FF99"
      }
    },
    {
      "scope": [
        "punctuation.definition.raw.markdown",
        "punctuation.definition.fenced.markdown"
      ],
      "settings": {
        "foreground": "#0A3322"
      }
    },
    {
      "scope": [
        "markup.quote",
        "markup.quote.markdown"
      ],
      "settings": {
        "foreground": "#88AA99",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.definition.quote.begin.markdown"
      ],
      "settings": {
        "foreground": "#00FF7F"
      }
    },
    {
      "scope": [
        "meta.separator.markdown"
      ],
      "settings": {
        "foreground": "#0F0F0F"
      }
    },
    {
      "scope": [
        "markup.list",
        "markup.list.numbered",
        "markup.list.unnumbered"
      ],
      "settings": {
        "foreground": "#66FFAA"
      }
    },
    {
      "scope": [
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#66FFAA"
      }
    },
    {
      "scope": [
        "markup.table"
      ],
      "settings": {
        "foreground": "#CCFFDD"
      }
    },
    {
      "scope": [
        "markup.table.header"
      ],
      "settings": {
        "foreground": "#88FFBB",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "punctuation.definition.table.markdown",
        "meta.table.separator.markdown"
      ],
      "settings": {
        "foreground": "#0A3322"
      }
    },
    {
      "scope": [
        "meta.embedded.block.frontmatter",
        "punctuation.definition.metadata.markdown"
      ],
      "settings": {
        "foreground": "#88AA99"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#00FF7F"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#22CC77"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#66FFAA"
      }
    },
    {
      "scope": [
        "markup.input.checkbox"
      ],
      "settings": {
        "foreground": "#00FF7F"
      }
    },
    {
      "scope": [
        "meta.image.inline",
        "meta.image.reference"
      ],
      "settings": {
        "foreground": "#88FFBB"
      }
    },
    {
      "scope": [
        "entity.name.tag.html",
        "entity.name.tag.xml"
      ],
      "settings": {
        "foreground": "#F7B883",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.tag.structure.any.html",
        "entity.name.tag.block.any.html"
      ],
      "settings": {
        "foreground": "#FFD166",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.tag.inline.any.html"
      ],
      "settings": {
        "foreground": "#EADCB2"
      }
    },
    {
      "scope": [
        "entity.name.tag.script.html",
        "entity.name.tag.style.html"
      ],
      "settings": {
        "foreground": "#FF3CAC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.xml"
      ],
      "settings": {
        "foreground": "#EADCB2",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.class.html",
        "entity.other.attribute-name.class.css"
      ],
      "settings": {
        "foreground": "#C8B0FF",
        "fontStyle": "italic bold"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.id.html",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#4CFFCA",
        "fontStyle": "italic bold"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.style.html"
      ],
      "settings": {
        "foreground": "#FF8BDA",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.event.html"
      ],
      "settings": {
        "foreground": "#D8C8FF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string.quoted.double.html",
        "string.quoted.single.html"
      ],
      "settings": {
        "foreground": "#00F5A0"
      }
    },
    {
      "scope": [
        "meta.attribute-with-value.html string"
      ],
      "settings": {
        "foreground": "#98FF66"
      }
    },
    {
      "scope": [
        "punctuation.definition.tag.begin.html",
        "punctuation.definition.tag.end.html"
      ],
      "settings": {
        "foreground": "#A6AAB4"
      }
    },
    {
      "scope": [
        "punctuation.definition.tag.html",
        "punctuation.separator.key-value.html"
      ],
      "settings": {
        "foreground": "#8E93A6"
      }
    },
    {
      "scope": [
        "punctuation.definition.string.begin.html",
        "punctuation.definition.string.end.html"
      ],
      "settings": {
        "foreground": "#9AA0B4"
      }
    },
    {
      "scope": [
        "comment.block.html",
        "punctuation.definition.comment.html"
      ],
      "settings": {
        "foreground": "#8E93A6",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "constant.character.entity.html",
        "constant.character.entity.named.html"
      ],
      "settings": {
        "foreground": "#F2C97D",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "punctuation.definition.entity.html"
      ],
      "settings": {
        "foreground": "#FFD166"
      }
    },
    {
      "scope": [
        "meta.tag.sgml.doctype.html",
        "entity.name.tag.doctype.html"
      ],
      "settings": {
        "foreground": "#FF3CAC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "keyword.doctype.xml"
      ],
      "settings": {
        "foreground": "#FF3CAC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "source.css.embedded.html"
      ],
      "settings": {
        "foreground": "#E0CCFF"
      }
    },
    {
      "scope": [
        "meta.embedded.block.css"
      ],
      "settings": {
        "foreground": "#D7C7FF"
      }
    },
    {
      "scope": [
        "source.js.embedded.html",
        "source.javascript.embedded.html"
      ],
      "settings": {
        "foreground": "#F7B883"
      }
    },
    {
      "scope": [
        "meta.embedded.block.javascript"
      ],
      "settings": {
        "foreground": "#EADCB2"
      }
    },
    {
      "scope": [
        "entity.name.tag.form.html",
        "entity.name.tag.input.html",
        "entity.name.tag.button.html"
      ],
      "settings": {
        "foreground": "#79E49A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.form.html"
      ],
      "settings": {
        "foreground": "#98FF66",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.tag.table.html",
        "entity.name.tag.tr.html",
        "entity.name.tag.td.html",
        "entity.name.tag.th.html"
      ],
      "settings": {
        "foreground": "#4CFFCA",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.tag.img.html",
        "entity.name.tag.video.html",
        "entity.name.tag.audio.html"
      ],
      "settings": {
        "foreground": "#FFD166",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.tag.a.html"
      ],
      "settings": {
        "foreground": "#4CFFCA",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.href.html"
      ],
      "settings": {
        "foreground": "#00F5A0",
        "fontStyle": "italic bold"
      }
    },
    {
      "scope": [
        "entity.name.tag.header.html",
        "entity.name.tag.main.html",
        "entity.name.tag.footer.html",
        "entity.name.tag.nav.html",
        "entity.name.tag.aside.html",
        "entity.name.tag.section.html",
        "entity.name.tag.article.html",
        "entity.name.tag.figure.html",
        "entity.name.tag.figcaption.html"
      ],
      "settings": {
        "foreground": "#C8B0FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "text.html.basic"
      ],
      "settings": {
        "foreground": "#F7F8FA"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#88FFBB",
    "string": "#55FF99",
    "number": "#AAFFDD",
    "keyword": "#00FF7F",
    "type": "#AAFFDD"
  }
}