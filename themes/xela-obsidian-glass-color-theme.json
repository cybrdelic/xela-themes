{
  "$schema": "vscode://schemas/color-theme",
  "name": "XELA Obsidian Glass — Black + Glass",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "focusBorder": "#7DD3FCAA",
    "selection.background": "#7DD3FC33",
    "titleBar.activeBackground": "#000000",
    "titleBar.inactiveBackground": "#000000",
    "titleBar.activeForeground": "#EAF2FF",
    "titleBar.inactiveForeground": "#A6AAB4",
    "titleBar.border": "#0F0F0F",
    "activityBar.background": "#000000",
    "activityBar.foreground": "#EAF2FF",
    "activityBar.inactiveForeground": "#9AA0AB",
    "activityBar.activeBorder": "#7DD3FC",
    "activityBar.border": "#0F0F0F",
    "activityBarBadge.background": "#7DD3FC",
    "activityBarBadge.foreground": "#03121E",
    "sideBar.background": "#000000",
    "sideBar.foreground": "#EAF2FF",
    "sideBar.border": "#0F0F0F",
    "statusBar.background": "#000000",
    "statusBar.foreground": "#EAF2FF",
    "statusBar.border": "#0F0F0F",
    "panel.background": "#000000",
    "panel.border": "#0F0F0F",
    "editorGroupHeader.tabsBackground": "#000000",
    "editorGroupHeader.tabsBorder": "#0D0D0D",
    "tab.activeBackground": "#000000",
    "tab.inactiveBackground": "#000000",
    "tab.border": "#000000",
    "tab.activeForeground": "#EAF2FF",
    "tab.inactiveForeground": "#A6AAB4",
    "tab.activeBorderTop": "#7DD3FC",
    "editor.background": "#000000",
    "editor.foreground": "#EAF2FF",
    "editor.lineHighlightBackground": "#0D0D0D",
    "editor.selectionBackground": "#7DD3FC33",
    "editorCursor.foreground": "#7DD3FC",
    "editorHoverWidget.background": "#0A0A0ACC",
    "editorHoverWidget.border": "#1E293B",
    "editorHoverWidget.foreground": "#EAF2FF",
    "editorWidget.background": "#0A0A0ACC",
    "editorWidget.border": "#1E293B",
    "widget.shadow": "#000000CC",
    "dropdown.background": "#0A0A0A",
    "dropdown.border": "#1E293B",
    "quickInput.background": "#0A0A0ACC",
    "quickInput.foreground": "#EAF2FF",
    "list.activeSelectionBackground": "#0F0F0F",
    "list.hoverBackground": "#0D0D0D",
    "list.focusBackground": "#0A0A0A",
    "button.background": "#7DD3FC",
    "button.hoverBackground": "#BAE6FD",
    "button.foreground": "#03121E",
    "terminal.background": "#000000",
    "terminal.foreground": "#EAF2FF",
    "terminalCursor.foreground": "#7DD3FC",
    "terminal.ansiBlue": "#7DD3FC",
    "terminal.ansiCyan": "#67E8F9",
    "terminal.ansiMagenta": "#F0ABFC",
    "terminal.ansiGreen": "#5EEAD4",
    "terminal.ansiYellow": "#FDE68A",
    "terminal.ansiRed": "#FB7185",
    "terminal.ansiBrightBlue": "#93C5FD",
    "terminal.ansiBrightCyan": "#A5F3FC",
    "terminal.ansiBrightMagenta": "#E9D5FF",
    "terminal.ansiBrightGreen": "#99F6E4",
    "terminal.ansiBrightYellow": "#FEF3C7",
    "terminal.ansiBrightRed": "#FCA5A5",
    "terminal.ansiWhite": "#F5F7FA",
    "terminal.ansiBlack": "#000000",
    "terminal.ansiBrightBlack": "#475569",
    "terminal.ansiBrightWhite": "#FFFFFF"
  },
  "tokenColors": [
    {
      "scope": [
        "keyword"
      ],
      "settings": {
        "foreground": "#93C5FD",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#67E8F9"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#99F6E4"
      }
    },
    {
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#FDE68A"
      }
    },
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#94A3B8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.1.markdown",
        "markup.heading.setext.1.markdown"
      ],
      "settings": {
        "foreground": "#EAF2FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.2.markdown",
        "markup.heading.setext.2.markdown"
      ],
      "settings": {
        "foreground": "#7DD3FC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.3.markdown"
      ],
      "settings": {
        "foreground": "#67E8F9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.4.markdown"
      ],
      "settings": {
        "foreground": "#F0ABFC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.5.markdown"
      ],
      "settings": {
        "foreground": "#99F6E4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "heading.6.markdown"
      ],
      "settings": {
        "foreground": "#94A3B8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold",
        "markup.bold.markdown"
      ],
      "settings": {
        "foreground": "#F5F7FA",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "punctuation.definition.bold.markdown"
      ],
      "settings": {
        "foreground": "#93C5FD"
      }
    },
    {
      "scope": [
        "markup.italic",
        "markup.italic.markdown"
      ],
      "settings": {
        "foreground": "#EAF2FF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.definition.italic.markdown"
      ],
      "settings": {
        "foreground": "#94A3B8"
      }
    },
    {
      "scope": [
        "markup.strikethrough",
        "markup.strike",
        "markup.deleted"
      ],
      "settings": {
        "fontStyle": "strikethrough",
        "foreground": "#FCA5A5"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "markup.underline.link.markdown",
        "markup.link",
        "meta.link",
        "meta.link.inline",
        "meta.link.reference"
      ],
      "settings": {
        "foreground": "#7DD3FC",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#EAF2FF"
      }
    },
    {
      "scope": [
        "string.other.link.description.markdown"
      ],
      "settings": {
        "foreground": "#F0ABFC"
      }
    },
    {
      "scope": [
        "constant.other.reference.link.markdown"
      ],
      "settings": {
        "foreground": "#94A3B8"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.inline",
        "markup.inline.code",
        "markup.inline.raw.string.markdown",
        "markup.raw.inline.markdown"
      ],
      "settings": {
        "foreground": "#FDE68A"
      }
    },
    {
      "scope": [
        "markup.fenced_code.block.markdown",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#FDE68A"
      }
    },
    {
      "scope": [
        "punctuation.definition.raw.markdown",
        "punctuation.definition.fenced.markdown"
      ],
      "settings": {
        "foreground": "#1E293B"
      }
    },
    {
      "scope": [
        "markup.quote",
        "markup.quote.markdown"
      ],
      "settings": {
        "foreground": "#94A3B8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.definition.quote.begin.markdown"
      ],
      "settings": {
        "foreground": "#7DD3FC"
      }
    },
    {
      "scope": [
        "meta.separator.markdown"
      ],
      "settings": {
        "foreground": "#1E293B"
      }
    },
    {
      "scope": [
        "markup.list",
        "markup.list.numbered",
        "markup.list.unnumbered"
      ],
      "settings": {
        "foreground": "#FDE68A"
      }
    },
    {
      "scope": [
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#FDE68A"
      }
    },
    {
      "scope": [
        "markup.table"
      ],
      "settings": {
        "foreground": "#EAF2FF"
      }
    },
    {
      "scope": [
        "markup.table.header"
      ],
      "settings": {
        "foreground": "#93C5FD",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "punctuation.definition.table.markdown",
        "meta.table.separator.markdown"
      ],
      "settings": {
        "foreground": "#1E293B"
      }
    },
    {
      "scope": [
        "meta.embedded.block.frontmatter",
        "punctuation.definition.metadata.markdown"
      ],
      "settings": {
        "foreground": "#94A3B8"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#5EEAD4"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#FB7185"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#FDE68A"
      }
    },
    {
      "scope": [
        "markup.input.checkbox"
      ],
      "settings": {
        "foreground": "#7DD3FC"
      }
    },
    {
      "scope": [
        "meta.image.inline",
        "meta.image.reference"
      ],
      "settings": {
        "foreground": "#7DD3FC"
      }
    },
    {
      "scope": [
        "entity.name.tag.html",
        "entity.name.tag.xml"
      ],
      "settings": {
        "foreground": "#F7B883",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.tag.structure.any.html",
        "entity.name.tag.block.any.html"
      ],
      "settings": {
        "foreground": "#FFD166",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.tag.inline.any.html"
      ],
      "settings": {
        "foreground": "#EADCB2"
      }
    },
    {
      "scope": [
        "entity.name.tag.script.html",
        "entity.name.tag.style.html"
      ],
      "settings": {
        "foreground": "#FF3CAC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.xml"
      ],
      "settings": {
        "foreground": "#EADCB2",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.class.html",
        "entity.other.attribute-name.class.css"
      ],
      "settings": {
        "foreground": "#C8B0FF",
        "fontStyle": "italic bold"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.id.html",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#4CFFCA",
        "fontStyle": "italic bold"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.style.html"
      ],
      "settings": {
        "foreground": "#FF8BDA",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.event.html"
      ],
      "settings": {
        "foreground": "#D8C8FF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string.quoted.double.html",
        "string.quoted.single.html"
      ],
      "settings": {
        "foreground": "#00F5A0"
      }
    },
    {
      "scope": [
        "meta.attribute-with-value.html string"
      ],
      "settings": {
        "foreground": "#98FF66"
      }
    },
    {
      "scope": [
        "punctuation.definition.tag.begin.html",
        "punctuation.definition.tag.end.html"
      ],
      "settings": {
        "foreground": "#A6AAB4"
      }
    },
    {
      "scope": [
        "punctuation.definition.tag.html",
        "punctuation.separator.key-value.html"
      ],
      "settings": {
        "foreground": "#8E93A6"
      }
    },
    {
      "scope": [
        "punctuation.definition.string.begin.html",
        "punctuation.definition.string.end.html"
      ],
      "settings": {
        "foreground": "#9AA0B4"
      }
    },
    {
      "scope": [
        "comment.block.html",
        "punctuation.definition.comment.html"
      ],
      "settings": {
        "foreground": "#8E93A6",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "constant.character.entity.html",
        "constant.character.entity.named.html"
      ],
      "settings": {
        "foreground": "#F2C97D",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "punctuation.definition.entity.html"
      ],
      "settings": {
        "foreground": "#FFD166"
      }
    },
    {
      "scope": [
        "meta.tag.sgml.doctype.html",
        "entity.name.tag.doctype.html"
      ],
      "settings": {
        "foreground": "#FF3CAC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "keyword.doctype.xml"
      ],
      "settings": {
        "foreground": "#FF3CAC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "source.css.embedded.html"
      ],
      "settings": {
        "foreground": "#E0CCFF"
      }
    },
    {
      "scope": [
        "meta.embedded.block.css"
      ],
      "settings": {
        "foreground": "#D7C7FF"
      }
    },
    {
      "scope": [
        "source.js.embedded.html",
        "source.javascript.embedded.html"
      ],
      "settings": {
        "foreground": "#F7B883"
      }
    },
    {
      "scope": [
        "meta.embedded.block.javascript"
      ],
      "settings": {
        "foreground": "#EADCB2"
      }
    },
    {
      "scope": [
        "entity.name.tag.form.html",
        "entity.name.tag.input.html",
        "entity.name.tag.button.html"
      ],
      "settings": {
        "foreground": "#79E49A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.form.html"
      ],
      "settings": {
        "foreground": "#98FF66",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.tag.table.html",
        "entity.name.tag.tr.html",
        "entity.name.tag.td.html",
        "entity.name.tag.th.html"
      ],
      "settings": {
        "foreground": "#4CFFCA",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.tag.img.html",
        "entity.name.tag.video.html",
        "entity.name.tag.audio.html"
      ],
      "settings": {
        "foreground": "#FFD166",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.tag.a.html"
      ],
      "settings": {
        "foreground": "#4CFFCA",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.href.html"
      ],
      "settings": {
        "foreground": "#00F5A0",
        "fontStyle": "italic bold"
      }
    },
    {
      "scope": [
        "entity.name.tag.header.html",
        "entity.name.tag.main.html",
        "entity.name.tag.footer.html",
        "entity.name.tag.nav.html",
        "entity.name.tag.aside.html",
        "entity.name.tag.section.html",
        "entity.name.tag.article.html",
        "entity.name.tag.figure.html",
        "entity.name.tag.figcaption.html"
      ],
      "settings": {
        "foreground": "#C8B0FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "text.html.basic"
      ],
      "settings": {
        "foreground": "#F7F8FA"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#67E8F9",
    "string": "#99F6E4",
    "number": "#FDE68A",
    "keyword": "#93C5FD",
    "type": "#E9D5FF"
  }
}