  "xPackLabel": "XELA Tech Nostalgia",
  "xThemeFamily": "Gaming Console",
  "xThemeEra": "2000s",
  "xThemeInspiration": "PlayStation 2 XMB interface with iconic towers and pure black void",
  "xColorPhilosophy": "Icy blue towers (#5A9CC9, #7AB8E8) floating in absolute black space",
