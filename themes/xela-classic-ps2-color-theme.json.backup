  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": {
        "foreground": "#445566",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "storage", "storage.type"],
      "settings": {
        "foreground": "#B586D4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["storage.modifier", "storage.type.function"],
      "settings": {
        "foreground": "#B586D4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["constant", "variable.other.constant"],
      "settings": {
        "foreground": "#6AB0D0"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#6AB0D0"
      }
    },
    {
      "scope": ["constant.other.symbol", "constant.other.enum"],
      "settings": {
        "foreground": "#E8B570"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.interpolated"],
      "settings": {
        "foreground": "#80C0A0"
      }
    },
    {
      "scope": "string.template",
      "settings": {
        "foreground": "#80C0A0"
      }
    },
    {
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#6AB0D0"
      }
    },
    {
      "scope": ["variable", "meta.definition.variable"],
      "settings": {
        "foreground": "#8BA6C0"
      }
    },
    {
      "scope": ["variable.parameter", "meta.function.parameter"],
      "settings": {
        "foreground": "#9AC0D8"
      }
    },
    {
      "scope": ["support.variable.property", "variable.other.property"],
      "settings": {
        "foreground": "#9AC0D8"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#7AB8E8"
      }
    },
    {
      "scope": ["meta.function-call", "support.function.console"],
      "settings": {
        "foreground": "#7AB8E8"
      }
    },
    {
      "scope": ["entity.name.type", "support.class", "support.type"],
      "settings": {
        "foreground": "#E8B570"
      }
    },
    {
      "scope": ["support.type.property-name", "support.type.primitive"],
      "settings": {
        "foreground": "#E8B570"
      }
    },
    {
      "scope": ["support.constant", "support.constant.property-value"],
      "settings": {
