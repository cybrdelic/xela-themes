        "foreground": "#FFFF55"
      }
    },
    {
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#FFFF55"
      }
    },
    {
      "scope": [
        "meta.embedded",
        "source.groovy.embedded"
      ],
      "settings": {
        "foreground": "#FFFF55"
      }
    },
    {
      "scope": [
        "invalid"
      ],
      "settings": {
        "foreground": "#FF5555",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
