  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#AAAA55",
        "fontStyle": "italic"
      },
      "peekView.border": "#55FFFF",
      "quickInput.background": "#000088",
      "quickInput.foreground": "#FFFF55",
      "editorIndentGuide.background1": "#00005550",
      "editorIndentGuide.activeBackground1": "#55FFFF50",
      "gitDecoration.addedResourceForeground": "#81b88b"
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#C679EC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#55FF55"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted"
      ],
      "settings": {
        "foreground": "#FFFF55"
      }
    },
    {
      "scope": [
        "variable",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#FFFF55"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#55FFFF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#E9D2A5",
