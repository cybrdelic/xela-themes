  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#B8A597",
        "fontStyle": "italic"
      },
      "peekView.border": "#007ACC",
      "quickInput.background": "#FFF3E3",
      "quickInput.foreground": "#2F1F1A",
      "gitDecoration.addedResourceForeground": "#81b88b",
      "selection.background": "#E86A3330",
      "focusBorder": "#E86A33"
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#C75180",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "keyword.control"
      ],
      "settings": {
        "foreground": "#E86A33"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#2E8A8C"
      }
    },
    {
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#2E668A"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#381A11"
      }
    },
    {
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#A7693E"
      }
    },
    {
      "scope": [
        "constant",
        "constant.language"
      ],
      "settings": {
        "foreground": "#B85C9E"
      }
    },
    {
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#FFB347"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#D7772A"
      }
    },
    {
      "scope": [
        "punctuation.definition.string",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#C75180"
      }
    },
    {
      "scope": [
        "support.function",
        "entity.name.function.preprocessor"
      ],
      "settings": {
        "foreground": "#4DABA8"
      }
    },
    {
      "scope": [
        "support.constant",
        "support.variable"
      ],
      "settings": {
        "foreground": "#A0634C"
      }
    },
    {
      "scope": [
        "meta.decorator",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#C75180"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#2E8A8C"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.tag.html",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#C75180",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext"
      ],
      "settings": {
        "foreground": "#E86A33"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#2E8A8C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#C75180",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#482222",
        "background": "#F3DFC6"
      }
    },
    {
      "scope": [
        "markup.list"
      ],
      "settings": {
        "foreground": "#A0634C"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#2E9E3B",
        "background": "#F3DFC680"
      }
    },
    {
      "scope": [
        "constant.character.entity"
      ],
      "settings": {
        "foreground": "#4DABA8"
      }
    }
  ],
  "semanticTokenColors": {
    "variable": "#381A11",
    "variable.defaultLibrary": "#381A11",
    "parameter": "#A7693E",
    "property": "#482222",
    "function": "#2E8A8C",
