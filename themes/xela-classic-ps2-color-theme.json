  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#445566",
        "fontStyle": "italic"
      },
      "peekView.border": "#0099FF",
      "quickInput.background": "#001A33"
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#9966FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.modifier",
        "storage.type.function"
      ],
      "settings": {
        "foreground": "#9966FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "constant",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#6AB0D0"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#6AB0D0"
      }
    },
    {
      "scope": [
        "constant.other.symbol",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#E8B570"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#80C0A0"
      }
    },
    {
      "scope": "string.template",
      "settings": {
        "foreground": "#80C0A0"
      }
    },
    {
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#6AB0D0"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#B0E8E8"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameter"
      ],
      "settings": {
        "foreground": "#AACCEE"
      }
    },
    {
      "scope": [
        "support.variable.property",
